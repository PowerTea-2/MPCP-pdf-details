  mpcp_nat_token(NULL, psk, sizeof(psk), tok1) != MPCP_OK);
  P3_CHECK("T-P3-05e null psk -> error",
  mpcp_nat_token(nonce, NULL, sizeof(psk), tok1) != MPCP_OK);
