  const uint32_t CHUNKS    = 50;
  const uint32_t PORT_BASE  = 10000;
  const uint32_t PORT_RANGE = 55000;
  /* Build two minimal sessions with the same key to test determinism */
  mpcp_config_t cfg; mpcp_config_defaults(&cfg);
  cfg.port_base  = PORT_BASE;
  cfg.port_range = PORT_RANGE;
  mpcp_session_t sess1, sess2;
