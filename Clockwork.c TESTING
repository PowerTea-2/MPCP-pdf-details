  int64_t target = (int64_t)tzero_ns + (int64_t)scaled;
  int32_t jit = schedule_jitter_ns(sess, seq);
  out[i].jitter_ns = jit;
  out[i].expected_arrival_ns = (target + jit > 0) ? (uint64_t)(target + jit) : tzero_ns;
  uint8_t sub = 0;
  uint16_t p = blink_hop_port_subidx(sess, cfg, seq, sub);
  for (;;) {
  bool collides = false;
  uint32_t j0 = (i > 10u) ? (i - 10u) : 0u;
