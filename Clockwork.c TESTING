/* pipeline_backoff_1us removed: condvar ring replaces all spinwait loops */
int mpcp_ring_init(mpcp_ring_t *r, uint32_t depth, uint32_t chunk_pad_size)
{
if (!r || depth == 0 || chunk_pad_size == 0) return MPCP_ERR_PARAM;
r->depth = depth;
atomic_store_explicit(&r->head,   0u,    memory_order_relaxed);
atomic_store_explicit(&r->tail,   0u,    memory_order_relaxed);
atomic_store_explicit(&r->closed, false, memory_order_relaxed);
pthread_mutex_init(&r->mu, NULL);
pthread_cond_init(&r->not_full,  NULL);
pthread_cond_init(&r->not_empty, NULL);
r->slots = calloc(depth, sizeof(mpcp_ring_slot_t));
if (!r->slots) return MPCP_ERR_ALLOC;
size_t buf_cap = (size_t)chunk_pad_size + 16u;  
for (uint32_t i = 0; i < depth; i++) {
r->slots[i].buf = malloc(buf_cap);
if (!r->slots[i].buf) {
for (uint32_t j = 0; j < i; j++) free(r->slots[j].buf);
free(r->slots);
r->slots = NULL;
return MPCP_ERR_ALLOC;
}
r->slots[i].buf_capacity = buf_cap;
atomic_store_explicit(&r->slots[i].state,
(int)MPCP_SLOT_EMPTY,
memory_order_relaxed);
}
return MPCP_OK;
}
void mpcp_ring_destroy(mpcp_ring_t *r)
{
if (!r || !r->slots) return;
for (uint32_t i = 0; i < r->depth; i++) {
if (r->slots[i].buf) {
sodium_memzero(r->slots[i].buf, r->slots[i].buf_capacity);
free(r->slots[i].buf);
r->slots[i].buf = NULL;
}
}
free(r->slots);
r->slots = NULL;
pthread_cond_destroy(&r->not_empty);
pthread_cond_destroy(&r->not_full);
pthread_mutex_destroy(&r->mu);
}
mpcp_ring_slot_t *mpcp_ring_claim(mpcp_ring_t *r)
{
for (;;) {
uint32_t h    = atomic_load_explicit(&r->head, memory_order_relaxed);
uint32_t idx  = h % r->depth;
int      st   = atomic_load_explicit(&r->slots[idx].state,
memory_order_acquire);
if (st == (int)MPCP_SLOT_EMPTY) {
/* CAS: EMPTY → FILLING */
int expected = (int)MPCP_SLOT_EMPTY;
if (atomic_compare_exchange_strong_explicit(
&r->slots[idx].state,
&expected, (int)MPCP_SLOT_FILLING,
memory_order_acq_rel, memory_order_acquire)) {
atomic_fetch_add_explicit(&r->head, 1u, memory_order_relaxed);
return &r->slots[idx];
}
}
if (atomic_load_explicit(&r->closed, memory_order_acquire)) return NULL;
/* Block on condvar instead of busy-spinning */
pthread_mutex_lock(&r->mu);
h   = atomic_load_explicit(&r->head, memory_order_relaxed);
idx = h % r->depth;
st  = atomic_load_explicit(&r->slots[idx].state, memory_order_acquire);
if (st != (int)MPCP_SLOT_EMPTY &&
!atomic_load_explicit(&r->closed, memory_order_acquire))
pthread_cond_wait(&r->not_full, &r->mu);
pthread_mutex_unlock(&r->mu);
}
}
void mpcp_ring_publish(mpcp_ring_t *r, mpcp_ring_slot_t *s)
{
atomic_store_explicit(&s->state, (int)MPCP_SLOT_FULL, memory_order_release);
pthread_mutex_lock(&r->mu);
pthread_cond_signal(&r->not_empty);
pthread_mutex_unlock(&r->mu);
}
mpcp_ring_slot_t *mpcp_ring_consume(mpcp_ring_t *r)
{
/* Fast path: item already ready */
uint32_t t   = atomic_load_explicit(&r->tail, memory_order_relaxed);
uint32_t idx = t % r->depth;
int      st  = atomic_load_explicit(&r->slots[idx].state, memory_order_acquire);
if (st == (int)MPCP_SLOT_FULL) {
atomic_fetch_add_explicit(&r->tail, 1u, memory_order_relaxed);
return &r->slots[idx];
}
/* Ring drained and closed: signal EOF to consumer */
if (atomic_load_explicit(&r->closed, memory_order_acquire) &&
st == (int)MPCP_SLOT_EMPTY)
return NULL;
/* Slow path: block for up to 1 ms then return NULL (caller checks done) */
pthread_mutex_lock(&r->mu);
struct timespec _ts;
clock_gettime(CLOCK_REALTIME, &_ts);
_ts.tv_nsec += 1000000L;
if (_ts.tv_nsec >= 1000000000L) { _ts.tv_sec++; _ts.tv_nsec -= 1000000000L; }
t   = atomic_load_explicit(&r->tail, memory_order_relaxed);
idx = t % r->depth;
st  = atomic_load_explicit(&r->slots[idx].state, memory_order_acquire);
if (st != (int)MPCP_SLOT_FULL)
pthread_cond_timedwait(&r->not_empty, &r->mu, &_ts);
pthread_mutex_unlock(&r->mu);
/* Re-evaluate after wakeup or timeout */
t   = atomic_load_explicit(&r->tail, memory_order_relaxed);
idx = t % r->depth;
st  = atomic_load_explicit(&r->slots[idx].state, memory_order_acquire);
if (st == (int)MPCP_SLOT_FULL) {
atomic_fetch_add_explicit(&r->tail, 1u, memory_order_relaxed);
return &r->slots[idx];
}
return NULL;
}
void mpcp_ring_release(mpcp_ring_t *r, mpcp_ring_slot_t *s)
{
sodium_memzero(s->buf, s->buf_capacity);
atomic_store_explicit(&s->state, (int)MPCP_SLOT_EMPTY, memory_order_release);
pthread_mutex_lock(&r->mu);
pthread_cond_signal(&r->not_full);
pthread_mutex_unlock(&r->mu);
}
void mpcp_ring_release_plain(mpcp_ring_t *r, mpcp_ring_slot_t *s)
{
atomic_store_explicit(&s->state, (int)MPCP_SLOT_EMPTY, memory_order_release);
pthread_mutex_lock(&r->mu);
pthread_cond_signal(&r->not_full);
pthread_mutex_unlock(&r->mu);
}
void mpcp_dedup_init(mpcp_dedup_t *d)
{
memset(d, 0, sizeof(*d));
}
bool mpcp_dedup_accept(mpcp_dedup_t *d, uint32_t seq)
{
if (seq >= MPCP_DEDUP_BITS) return false;  
uint32_t byte_idx = seq / 8u;
uint8_t  bit_mask = (uint8_t)(1u << (seq & 7u));
uint8_t prev = atomic_fetch_or_explicit(&d->bits[byte_idx],
bit_mask,
memory_order_acq_rel);
return (prev & bit_mask) == 0;  
}
static uint16_t chunk_port(const mpcp_session_t *sess,
const mpcp_config_t *cfg,
uint32_t seq)
{
uint8_t  ckey[32];
uint16_t port;
mpcp_get_chunk_params(sess, cfg, seq, ckey, &port);
sodium_memzero(ckey, sizeof(ckey));
return port;
}
static uint32_t __attribute__((unused)) ack_jitter_ms(const uint8_t *session_key,
uint32_t seq, uint32_t jitter_max)
{
if (jitter_max == 0) return 0;
uint8_t ikm[36];
memcpy(ikm, session_key, 32u);
ikm[32] = (uint8_t)(seq >> 24);
ikm[33] = (uint8_t)(seq >> 16);
ikm[34] = (uint8_t)(seq >>  8);
ikm[35] = (uint8_t)(seq);
uint8_t derived[4];
int rc = mpcp_hkdf(session_key, 32u,
ikm, sizeof(ikm),
"mpcp-v0.5-ack-jitter",
derived, sizeof(derived));
if (rc != MPCP_OK) return 0;
uint32_t raw = ((uint32_t)derived[0] << 24) | ((uint32_t)derived[1] << 16) |
((uint32_t)derived[2] <<  8) |  (uint32_t)derived[3];
return raw % (jitter_max + 1u);
}
static uint16_t __attribute__((unused)) retry_port(const mpcp_config_t *cfg,
mpcp_session_t *sess,
uint32_t chunk_idx, uint32_t retry_count)
{
return mpcp_retry_port(sess->session_key, sess->session_nonce,
chunk_idx, retry_count,
cfg->port_base, cfg->port_range);
}
static void setup_timing_thread(const mpcp_config_t *cfg)
{
cpu_set_t cpuset;
CPU_ZERO(&cpuset);
CPU_SET((size_t)cfg->timing_core_id, &cpuset);
(void)pthread_setaffinity_np(pthread_self(), sizeof(cpuset), &cpuset);
struct sched_param sp;
sp.sched_priority = 80;
(void)pthread_setschedparam(pthread_self(), SCHED_FIFO, &sp);
}
static int open_udp_socket_on_port(uint16_t port)
{
int fd = socket(AF_INET, SOCK_DGRAM, 0);
if (fd < 0) return -1;
int one = 1;
(void)setsockopt(fd, SOL_SOCKET, SO_REUSEADDR, &one, sizeof(one));
struct sockaddr_in addr;
memset(&addr, 0, sizeof(addr));
addr.sin_family      = AF_INET;
addr.sin_addr.s_addr = INADDR_ANY;
addr.sin_port        = htons(port);
if (bind(fd, (struct sockaddr *)(void *)&addr, sizeof(addr)) < 0) {
close(fd);
return -1;
}
return fd;
}
typedef struct {
mpcp_sender_ctx_t *ctx;
} reader_arg_t;
static void *thread_reader(void *arg)
{
reader_arg_t      *a   = arg;
mpcp_sender_ctx_t *ctx = a->ctx;
/* seq MUST start at block_base (absolute file offset), NOT 0.

- Using plan_full ensures remainder bytes are applied to the first
- N chunks of the entire file only — not reset at every block boundary. */
  uint32_t seq = ctx->block_base;
  for (uint32_t i = 0; i < ctx->block_size; i++) {
  if (atomic_load_explicit(&ctx->abort_flag, memory_order_relaxed))
  break;
  /* Absolute lookup: chunk_sz is correct for this position in the file */
  uint32_t chunk_sz = mpcp_chunk_data_size(&ctx->plan_full, seq);
  mpcp_ring_slot_t *slot = mpcp_ring_claim(&ctx->ring0);
  if (!slot) { atomic_store_explicit(&ctx->abort_flag, true, memory_order_relaxed); break; }
  slot->seq_index = seq++;
  slot->data_len  = chunk_sz;
  slot->flags     = ctx->plan_full.skip_compression
  ? MPCP_FLAG_SKIP_COMPRESSION : 0;
  if (i == ctx->block_size - 1u) slot->flags |= MPCP_FLAG_LAST_CHUNK;
  ssize_t n = read(ctx->file_fd, slot->buf, chunk_sz);
  if (n != (ssize_t)chunk_sz) {
  atomic_store_explicit(&ctx->abort_flag, true, memory_order_relaxed);
  mpcp_ring_release_plain(&ctx->ring0, slot);
  break;
  }
  mpcp_ring_publish(&ctx->ring0, slot);
  }
  atomic_store_explicit(&ctx->t1_done, true, memory_order_release);
  return NULL;
  }
  typedef struct {
  mpcp_sender_ctx_t *ctx;
  } compress_arg_t;
  static void *thread_compressor(void *arg)
  {
  compress_arg_t    *a   = arg;
  mpcp_sender_ctx_t *ctx = a->ctx;
  for (;;) {
  mpcp_ring_slot_t *in = mpcp_ring_consume(&ctx->ring0);
  if (!in) {
  /* Condvar ring: NULL means 1ms timeout expired or ring closed */
  if (atomic_load_explicit(&ctx->t1_done, memory_order_acquire))
  break;
  if (atomic_load_explicit(&ctx->abort_flag, memory_order_relaxed))
  break;
  continue;   /* re-try consume (already waited 1ms inside) */
  }
  mpcp_ring_slot_t *out = mpcp_ring_claim(&ctx->ring1);
  out->seq_index = in->seq_index;
  out->flags     = in->flags;
  if (ctx->plan.skip_compression) {
  out->data_len = in->data_len;
  memcpy(out->buf, in->buf, in->data_len);
  } else {
  size_t bound = ZSTD_compressBound(in->data_len);
  if (bound > out->buf_capacity) {
  out->data_len = in->data_len;
  out->flags   |= MPCP_FLAG_SKIP_COMPRESSION;
  memcpy(out->buf, in->buf, in->data_len);
  } else {
  size_t clen = ZSTD_compress(out->buf, out->buf_capacity,
  in->buf, in->data_len,
  ctx->cfg->zstd_level);
  if (ZSTD_isError(clen)) {
  out->data_len = in->data_len;
  out->flags   |= MPCP_FLAG_SKIP_COMPRESSION;
  memcpy(out->buf, in->buf, in->data_len);
  } else {
  out->data_len = (uint32_t)clen;
  }
  }
  }
  mpcp_ring_release_plain(&ctx->ring0, in);
  mpcp_ring_publish(&ctx->ring1, out);
  if (out->flags & MPCP_FLAG_LAST_CHUNK) break;
  }
  atomic_store_explicit(&ctx->t2_done, true, memory_order_release);
  return NULL;
  }
  typedef struct {
  mpcp_sender_ctx_t *ctx;
  } crypto_arg_t;
  static void *thread_crypto(void *arg)
  {
  crypto_arg_t      *a   = arg;
  mpcp_sender_ctx_t *ctx = a->ctx;
  for (;;) {
  mpcp_ring_slot_t *in = mpcp_ring_consume(&ctx->ring1);
  if (!in) {
  if (atomic_load_explicit(&ctx->t2_done, memory_order_acquire))
  break;
  if (atomic_load_explicit(&ctx->abort_flag, memory_order_relaxed))
  break;
  continue;   /* condvar ring already waited 1ms */
  }
  mpcp_ring_slot_t *out = mpcp_ring_claim(&ctx->ring2);
  if (!out) {
  mpcp_ring_release_plain(&ctx->ring1, in);
  break;
  }
  out->seq_index = in->seq_index;
  out->flags     = in->flags;
  out->data_len  = in->data_len;
  uint8_t  chunk_key[32];
  uint16_t _port;
  /* O(1) on-the-fly key+port — no keystream heap allocation */
  mpcp_get_chunk_params(ctx->sess, ctx->cfg, in->seq_index, chunk_key, &_port);
  int rc = mpcp_chunker_encrypt_chunk(
  in->buf, in->data_len,
  chunk_key,
  ctx->sess->session_nonce,
  in->seq_index,
  out->buf, &out->ct_len,
  out->nonce, in->flags,
  ctx->cfg->chunk_pad_size);
  sodium_memzero(chunk_key, sizeof(chunk_key));
  if (rc != MPCP_OK) {
  atomic_store_explicit(&ctx->abort_flag, true, memory_order_relaxed);
  mpcp_ring_release(&ctx->ring1, in);
  mpcp_ring_release(&ctx->ring2, out);
  break;
  }
  mpcp_ring_release(&ctx->ring1, in);
  mpcp_ring_publish(&ctx->ring2, out);
  if (out->flags & MPCP_FLAG_LAST_CHUNK) break;
  }
  return NULL;
  }
  typedef struct {
  mpcp_sender_ctx_t *ctx;
  int                ack_sock;  
  } sender_arg_t;
  static int send_chunk_packet(int sock,
  const struct sockaddr_in *peer,
  mpcp_session_t *sess,
  const mpcp_ring_slot_t *slot,
  uint8_t pkt_type,
  uint8_t retry_count,
  bool try_zerocopy)
  {
  #define SEND_PKT_MAX (MPCP_DATA_HDR_OFFSET + 63488u + 16u)
  uint8_t pkt_stack[SEND_PKT_MAX];
  size_t  pkt_len = (size_t)MPCP_DATA_HDR_OFFSET + slot->ct_len;
  uint8_t *pkt    = (pkt_len <= SEND_PKT_MAX) ? pkt_stack : NULL;
  if (!pkt) return MPCP_ERR_PARAM;
  (void)try_zerocopy;
  uint32_t magic_be = htonl(MPCP_MAGIC);
  memcpy(pkt,     &magic_be, 4);
  pkt[4] = MPCP_VERSION;
  pkt[5] = pkt_type;
  uint32_t seq_be = htonl(slot->seq_index);
  memcpy(pkt + 6,  &seq_be, 4);
  pkt[10] = retry_count;
  pkt[11] = slot->flags;
  uint32_t plen_be = htonl(slot->data_len);
  memcpy(pkt + 12, &plen_be, 4);
  memcpy(pkt + 16, slot->nonce, 24);
  uint64_t sched_ns = 0;
  if (sess && sess->blink_interval_ns > 0) {
  sched_ns = sess->blink_origin_ns
  + (uint64_t)slot->seq_index * sess->blink_interval_ns;
  }
  uint64_t sched_be = __builtin_bswap64(sched_ns);
  memcpy(pkt + 40, &sched_be, 8);
  memcpy(pkt + 48, slot->buf, slot->ct_len);
  ssize_t sent = sendto(sock, pkt, pkt_len, 0,
  (const struct sockaddr *)(const void *)peer,
  sizeof(*peer));
  return (sent > 0) ? MPCP_OK : MPCP_ERR_IO;
  }
/* =========================================================================
 * mpcp_sliding_window_t — helper functions
 *
 * Threading contract (mirrors the struct layout comments):
 *   mpcp_sw_init / mpcp_sw_destroy — called only from mpcp_sender_run(),
 *     single-threaded before any thread is spawned / after all are joined.
 *   mpcp_sw_kalman_update / mpcp_sw_advance_send_base — send thread only.
 *   mpcp_sw_ack_bit_set / mpcp_sw_ack_bit_test — ACK thread only.
 * ========================================================================= */

/* -------------------------------------------------------------------------
 * mpcp_sw_init — zero and initialise all four cache lines.
 *   window_size : maximum segments in flight (in chunks)
 *   rto_ns      : initial retransmission timeout in nanoseconds
 * Returns MPCP_OK or MPCP_ERR_ALLOC.
 * ---------------------------------------------------------------------- */
static int mpcp_sw_init(mpcp_sliding_window_t *sw,
                        uint32_t               window_size,
                        uint64_t               rto_ns)
{
    memset(sw, 0, sizeof(*sw));

    /* LINE 0 — sender-private */
    sw->window_size          = (uint64_t)window_size;
    sw->retx_timeout_ns      = rto_ns;
    sw->token_bucket_credits = (int64_t)window_size;
    sw->token_refill_rate    = Q32_FROM_INT(1); /* placeholder: 1 unit/ns */

    /* LINE 1 — ACK-private: allocate SACK bitmask */
    size_t mask_bytes = ((size_t)window_size + 7u) / 8u;
    if (mask_bytes == 0u) mask_bytes = 1u;
    sw->ack_mask = calloc(mask_bytes, 1u);
    if (!sw->ack_mask) return MPCP_ERR_ALLOC;
    sw->ack_mask_len = (uint64_t)mask_bytes;

    /* LINE 2 — shared atomics */
    atomic_store_explicit(&sw->shared_ack_base,   0u,
                          memory_order_relaxed);
    atomic_store_explicit(&sw->shared_window_adv, (uint64_t)window_size,
                          memory_order_relaxed);
    atomic_store_explicit(&sw->state_flags,        0u,
                          memory_order_relaxed);
    atomic_store_explicit(&sw->rtt_sample_ns,      0u,
                          memory_order_relaxed);
    atomic_store_explicit(&sw->generation,         0u,
                          memory_order_relaxed);

    /* LINE 3 — Kalman: seed estimate at half the initial RTO (µs, Q16.16).
     * P₀ = 100 µs² (high initial uncertainty), Q = 1, R = 10. */
    int32_t seed_ms  = (int32_t)(rto_ns / 2000000u);  /* ns→ms, halved */
    if (seed_ms < 1)     seed_ms = 1;
    if (seed_ms > 30000) seed_ms = 30000;
    sw->kf_rtt_estimate  = Q32_FROM_INT(seed_ms);
    sw->kf_rtt_min       = sw->kf_rtt_estimate;
    sw->kf_error_cov     = Q32_FROM_INT(100);
    sw->kf_process_noise = Q32_FROM_INT(1);
    sw->kf_meas_noise    = Q32_FROM_INT(10);
    sw->kf_rtt_variance  = Q32_FROM_INT(100);
    sw->kf_update_count  = 0u;

    return MPCP_OK;
}

/* -------------------------------------------------------------------------
 * mpcp_sw_destroy — release resources owned by the struct.
 * ---------------------------------------------------------------------- */
static void mpcp_sw_destroy(mpcp_sliding_window_t *sw)
{
    free(sw->ack_mask);
    sw->ack_mask     = NULL;
    sw->ack_mask_len = 0u;
}

/* -------------------------------------------------------------------------
 * mpcp_sw_kalman_update — FPU-free 1-D Kalman predict → update → RTO.
 *
 * Consumes the RTT sample published by the ACK thread via rtt_sample_ns
 * (acquire-load), resets the atomic to zero, then runs:
 *
 *   Predict:  x̂⁻ = x̂,  P⁻ = P + Q
 *   Update:   K   = P⁻/(P⁻+R),  x̂ += K·(z−x̂⁻),  P = (1−K)·P⁻
 *   Variance: σ² = (1−K)·σ² + K·(z−x̂⁻)²
 *   RTO:      RTO_µs = x̂ + 4·√σ²    (RFC 6298 analogue)
 *
 * All arithmetic is Q16.16 fixed-point (q32_t). √σ² is approximated with
 * three Newton-Raphson iterations on the raw int32 value.
 * ---------------------------------------------------------------------- */
static void mpcp_sw_kalman_update(mpcp_sliding_window_t *sw)
{
    /* Acquire-load: pairs with the release-store in thread_ack_handler. */
    uint64_t sample_ns = atomic_load_explicit(&sw->rtt_sample_ns,
                                              memory_order_acquire);
    if (sample_ns == 0u) return;

    /* Consume: reset before computing so a concurrent ACK can post a new one */
    atomic_store_explicit(&sw->rtt_sample_ns, 0u, memory_order_relaxed);

    /* ns → ms, clamp to [1, 30 000] ms then convert to Q16.16 */
    int32_t z_ms = (int32_t)(sample_ns / 1000000u);
    if (z_ms < 1)     z_ms = 1;
    if (z_ms > 30000) z_ms = 30000;
    q32_t z = Q32_FROM_INT(z_ms);

    /* --- Predict --------------------------------------------------------- */
    q32_t x_prior = sw->kf_rtt_estimate;   /* x̂⁻ = x̂  (F = 1) */
    q32_t p_prior = sw->kf_error_cov + sw->kf_process_noise;  /* P⁻ = P + Q */

    /* --- Update ---------------------------------------------------------- */
    q32_t denom = p_prior + sw->kf_meas_noise;
    q32_t K     = (denom != 0) ? Q32_DIV(p_prior, denom) : 0;
    sw->kf_gain = K;

    q32_t innov        = z - x_prior;
    sw->kf_innovation  = innov;

    sw->kf_rtt_estimate = x_prior + Q32_MUL(K, innov);
    sw->kf_error_cov    = Q32_MUL(Q32_ONE - K, p_prior);

    /* Running variance: σ² = (1−K)·σ² + K·innov² */
    q32_t innov_sq      = Q32_MUL(innov, innov);
    sw->kf_rtt_variance = Q32_MUL(Q32_ONE - K, sw->kf_rtt_variance)
                        + Q32_MUL(K, innov_sq);

    /* Track floor */
    if (sw->kf_update_count == 0u ||
        sw->kf_rtt_estimate < sw->kf_rtt_min)
        sw->kf_rtt_min = sw->kf_rtt_estimate;

    sw->kf_update_count++;

    /* --- Derive RTO ------------------------------------------------------- *
     * RTO_µs = x̂ + 4·σ,   σ = √(σ²)
     *
     * Fixed-point √: treat kf_rtt_variance as a Q16.16 number.
     * We need σ in the same units as x̂ (Q16.16 µs).
     *
     * √(Q16.16) = √(raw / 65536) → σ_int_µs ≈ isqrt(raw) / 256.
     * Newton–Raphson (3 iters) on the raw int32:
     *   s_{n+1} = (s_n + raw/s_n) / 2
     * --------------------------------------------------------------------- */
    int32_t raw = (int32_t)sw->kf_rtt_variance;
    if (raw < 1) raw = 1;
    int32_t s   = (raw >> 8) | 1;           /* seed: rough ≈ sqrt(raw) */
    s = (s + raw / s) / 2;
    s = (s + raw / s) / 2;
    s = (s + raw / s) / 2;
    /* s ≈ sqrt(raw Q16.16 value); σ in Q16.16 µs = s (already scaled) */
    q32_t sigma_q = (q32_t)s;

    q32_t rto_q_ms = sw->kf_rtt_estimate + (q32_t)(4 * sigma_q);

    /* Clamp: [1 ms, 30 000 ms (30 s)] */
    if (rto_q_ms < Q32_FROM_INT(1))     rto_q_ms = Q32_FROM_INT(1);
    if (rto_q_ms > Q32_FROM_INT(30000)) rto_q_ms = Q32_FROM_INT(30000);

    /* Q16.16 ms → integer ns */
    sw->retx_timeout_ns = (uint64_t)((int32_t)(rto_q_ms >> 16)) * 1000000u;
}

/* -------------------------------------------------------------------------
 * SACK bitmask helpers (ACK thread only).
 * ---------------------------------------------------------------------- */

/* Mark seq as selectively-acknowledged in the SACK bitmask. */
static void mpcp_sw_ack_bit_set(mpcp_sliding_window_t *sw, uint64_t seq)
{
    if (!sw->ack_mask) return;
    uint64_t mask_bits = sw->ack_mask_len * 8u;
    uint64_t off = seq & (mask_bits - 1u);
    sw->ack_mask[off / 8u] |= (uint8_t)(1u << (off % 8u));
}

/* Return true if seq has already been marked in the SACK bitmask. */
static bool mpcp_sw_ack_bit_test(const mpcp_sliding_window_t *sw, uint64_t seq)
{
    if (!sw->ack_mask) return false;
    uint64_t mask_bits = sw->ack_mask_len * 8u;
    uint64_t off = seq & (mask_bits - 1u);
    return (sw->ack_mask[off / 8u] & (uint8_t)(1u << (off % 8u))) != 0u;
}

/* -------------------------------------------------------------------------
 * mpcp_sw_advance_send_base — send thread only.
 *
 * Advances send_base to new_base (which comes from an acquire-load of
 * shared_ack_base), decrements inflight accordingly, and clears the SACK
 * bitmask bits that have slid out of the window.
 * ---------------------------------------------------------------------- */
static void mpcp_sw_advance_send_base(mpcp_sliding_window_t *sw,
                                      uint64_t               new_base)
{
    if (new_base <= sw->send_base) return;
    uint64_t delta = new_base - sw->send_base;
    if (delta > sw->inflight) delta = sw->inflight;
    sw->inflight -= delta;
    sw->send_base = new_base;
    /* ack_mask is ACK-thread-only — send thread must not touch it. */
}

/* ========================================================================= */

  static void *thread_sender(void *arg)
  {
  sender_arg_t      *a   = arg;
  mpcp_sender_ctx_t *ctx = a->ctx;
  uint32_t  ghost_idx = ctx->block_ghost_start;
  uint32_t  total_sent = 0;
  uint32_t  data_consumed = 0;
  int persist_sock = a->ack_sock;
  if (persist_sock < 0) {
  atomic_store_explicit(&ctx->abort_flag, true, memory_order_relaxed);
  return NULL;
  }
  bool use_blink_pacer = (ctx->sess->blink_interval_ns > 0);
  uint64_t _origin_ns = ctx->sess->t_zero_ns ? ctx->sess->t_zero_ns : ctx->sess->blink_origin_ns;
  uint64_t _blink_interval_ns = ctx->sess->blink_interval_ns;
  double   _drift = (ctx->sess->drift_coefficient > 0.0) ? ctx->sess->drift_coefficient : 1.0;
  double   _pid_i = 0.0;
  double   _pid_c = 0.0;
  const double _kp = 0.3;
  const double _ki = 0.02;
  uint32_t _block_size = ctx->block_size;
  uint32_t _block_base = ctx->block_base;
  while (data_consumed < _block_size) {
  if (atomic_load_explicit(&ctx->abort_flag, memory_order_relaxed))
  break;
  mpcp_ring_slot_t *slot = mpcp_ring_consume(&ctx->ring2);
  if (!slot) { continue; }  /* condvar ring already waited 1ms */
  uint32_t seq  = slot->seq_index;
  uint16_t port = use_blink_pacer
  ? blink_hop_port(ctx->sess, ctx->cfg, seq)
  : chunk_port(ctx->sess, ctx->cfg, seq);
  struct sockaddr_in dest;
  memcpy(&dest, ctx->peer_addr, sizeof(dest));
  dest.sin_port = htons(port);
  if (use_blink_pacer) {
  double scaled = (double)seq * (double)_blink_interval_ns * _drift;
  int64_t _abs_target_i = (int64_t)_origin_ns + (int64_t)scaled + (int64_t)_pid_c
                        + (int64_t)schedule_jitter_ns(ctx->sess, seq);
  uint64_t _abs_target = (_abs_target_i > 0) ? (uint64_t)_abs_target_i : _origin_ns;
  mpcp_precise_wait_ns(_abs_target, 50000ULL);
  }
  (void)send_chunk_packet(persist_sock, &dest, ctx->sess, slot,
  MPCP_TYPE_DATA_CHUNK, 0,
  ctx->cfg->zerocopy);
  data_consumed++;
  /* --- sw: record send, advance base if ACK thread published progress --- */
  mpcp_sliding_window_t *sw = &ctx->sw;
  sw->send_next++;
  sw->inflight++;
  sw->last_send_ns = mpcp_now_ns();
  /* Advance send_base from whatever shared_ack_base the ACK thread posted */
  uint64_t acked_base = atomic_load_explicit(&sw->shared_ack_base,
                                             memory_order_acquire);
  if (acked_base > sw->send_base)
      mpcp_sw_advance_send_base(sw, acked_base);
  /* Run Kalman if the ACK thread deposited a new RTT sample */
  if (atomic_load_explicit(&sw->rtt_sample_ns, memory_order_relaxed) != 0u)
      mpcp_sw_kalman_update(sw);
  if (use_blink_pacer) {
      double kf_ms = (double)(int32_t)(sw->kf_rtt_estimate >> 16);
      double err_ns = (kf_ms * 1000000.0) * 0.5;
      _pid_i += err_ns;
      if (_pid_i > 5000000.0) _pid_i = 5000000.0;
      if (_pid_i < -5000000.0) _pid_i = -5000000.0;
      _pid_c += (_kp * err_ns) + (_ki * _pid_i);
      if (_pid_c > 5000000.0) _pid_c = 5000000.0;
      if (_pid_c < -5000000.0) _pid_c = -5000000.0;
  }
  /* Inflight window gate: spin until there is credit.
   * retx_timeout_ns doubles as the gate spin limit — if we have been
   * stalled longer than one RTO something has gone wrong; let the
   * existing retry/abort path handle it. */
  if (sw->inflight >= sw->window_size) {
      uint64_t gate_deadline = sw->last_send_ns + sw->retx_timeout_ns;
      sw->window_size = atomic_load_explicit(&sw->shared_window_adv, memory_order_acquire);
      while (sw->inflight >= sw->window_size &&
             !atomic_load_explicit(&ctx->abort_flag, memory_order_relaxed)) {
          if (mpcp_now_ns() > gate_deadline) {
              atomic_store_explicit(&ctx->abort_flag, true, memory_order_relaxed);
              break;
          }
          struct timespec _ts = { .tv_sec = 0, .tv_nsec = 100000L }; /* 100 µs */
          nanosleep(&_ts, NULL);
          acked_base = atomic_load_explicit(&sw->shared_ack_base,
                                            memory_order_acquire);
          if (acked_base > sw->send_base)
              mpcp_sw_advance_send_base(sw, acked_base);
          if (atomic_load_explicit(&sw->rtt_sample_ns, memory_order_relaxed) != 0u)
              mpcp_sw_kalman_update(sw);
      }
  }
  { uint32_t _local = (seq >= _block_base) ? (seq - _block_base) : 0u;
  if (_local < _block_size && ctx->retry_cache && !ctx->retry_cache[_local]) {
  uint8_t *cached = malloc(slot->ct_len);
  if (cached) {
  memcpy(cached, slot->buf, slot->ct_len);
  ctx->retry_cache[_local]      = cached;
  ctx->retry_cache_lens[_local] = slot->ct_len;
  ctx->retry_data_lens[_local]  = slot->data_len;
  ctx->retry_flags[_local]      = slot->flags;
  memcpy(ctx->retry_nonces[_local], slot->nonce, 24);
  atomic_store_explicit(&ctx->sent_flag[_local], true, memory_order_relaxed);
  ctx->sent_time_ns[_local] = mpcp_now_ns();
  }
  }
  }
  total_sent++;
  if (ctx->cfg->ghost_chunks_enabled && ghost_idx < ctx->ghost_count && ghost_idx < ctx->block_ghost_end) {
  uint32_t gseq  = ctx->ghost_seqs[ghost_idx++];
  uint16_t gport = use_blink_pacer
  ? blink_hop_port(ctx->sess, ctx->cfg, gseq)
  : chunk_port(ctx->sess, ctx->cfg, gseq);
  uint8_t gkey[32];
  uint16_t _p2;
  /* O(1) key derivation — no keystream heap */
  mpcp_get_chunk_params(ctx->sess, ctx->cfg, gseq, gkey, &_p2);
  size_t  gct_len = 0;
  uint8_t gnonce[24];
  size_t  gbuf_sz = (size_t)ctx->cfg->chunk_pad_size + 16u;
  /* Stack allocation — max chunk_pad_size is 63488 B */
  uint8_t gbuf_stack[63504];
  uint8_t *gbuf = (gbuf_sz <= sizeof(gbuf_stack)) ? gbuf_stack : NULL;
  if (gbuf) {
  if (mpcp_chunker_generate_ghost(gkey, ctx->sess->session_nonce,
  gseq, ctx->cfg->chunk_pad_size,
  gbuf, &gct_len, gnonce) == MPCP_OK)
  {
  struct sockaddr_in gdest;
  memcpy(&gdest, ctx->peer_addr, sizeof(gdest));
  gdest.sin_port = htons(gport);
  {
  int gsock = persist_sock;
  if (gsock >= 0) {
  mpcp_ring_slot_t gslot;
  memset(&gslot, 0, sizeof(gslot));
  gslot.seq_index = gseq;
  gslot.flags     = 0;
  gslot.data_len  = ctx->cfg->chunk_pad_size;
  gslot.buf       = gbuf;
  gslot.ct_len    = gct_len;
  memcpy(gslot.nonce, gnonce, 24);
  (void)send_chunk_packet(gsock, &gdest,
  ctx->sess, &gslot,
  MPCP_TYPE_GHOST_CHUNK,
  0, ctx->cfg->zerocopy);
  }
  }
  total_sent++;
  sodium_memzero(gbuf, gbuf_sz);
  }
  /* no free — stack allocated */
  }
  sodium_memzero(gkey, sizeof(gkey));
  }
  mpcp_ring_release(&ctx->ring2, slot);
  }  
  while (ghost_idx < ctx->block_ghost_end &&
  !atomic_load_explicit(&ctx->abort_flag, memory_order_relaxed)) {
  uint32_t gseq  = ctx->ghost_seqs[ghost_idx++];
  uint16_t gport = use_blink_pacer
  ? blink_hop_port(ctx->sess, ctx->cfg, gseq)
  : chunk_port(ctx->sess, ctx->cfg, gseq);
  uint8_t  gkey[32]; uint16_t _gp2;
  /* O(1) key derivation — no keystream heap */
  mpcp_get_chunk_params(ctx->sess, ctx->cfg, gseq, gkey, &_gp2);
  size_t  gct_len;
  uint8_t gnonce[24];
  size_t  gbuf_sz = (size_t)ctx->cfg->chunk_pad_size + 16u;
  /* Stack allocation — max chunk_pad_size is 63488 B */
  uint8_t gbuf_stack[63504];
  uint8_t *gbuf = (gbuf_sz <= sizeof(gbuf_stack)) ? gbuf_stack : NULL;
  if (gbuf) {
  if (mpcp_chunker_generate_ghost(gkey, ctx->sess->session_nonce,
  gseq, ctx->cfg->chunk_pad_size,
  gbuf, &gct_len, gnonce) == MPCP_OK) {
  struct sockaddr_in gdest;
  memcpy(&gdest, ctx->peer_addr, sizeof(gdest));
  gdest.sin_port = htons(gport);
  mpcp_ring_slot_t gslot;
  memset(&gslot, 0, sizeof(gslot));
  gslot.seq_index = gseq;
  gslot.data_len  = ctx->cfg->chunk_pad_size;
  gslot.buf       = gbuf;
  gslot.ct_len    = gct_len;
  memcpy(gslot.nonce, gnonce, 24);
  (void)send_chunk_packet(persist_sock, &gdest, ctx->sess, &gslot,
  MPCP_TYPE_GHOST_CHUNK, 0, ctx->cfg->zerocopy);
  sodium_memzero(gbuf, gbuf_sz);
  }
  /* no free — stack allocated */
  }
  sodium_memzero(gkey, sizeof(gkey));
  total_sent++;
  }
  {
  struct timespec wait500 = {0, 500000000L};
  nanosleep(&wait500, NULL);
  uint64_t retry_timeout_ns = (uint64_t)(ctx->cfg->chunk_retry_timeout * 1e9);
  uint32_t max_retries = 8;
  uint32_t still_unacked;
  do {
  still_unacked = 0;
  uint64_t now = mpcp_now_ns();
  for (uint32_t i = 0; i < _block_size; i++) {
  if (!atomic_load_explicit(&ctx->sent_flag[i], memory_order_relaxed))
  continue;
  if (!ctx->retry_cache || !ctx->retry_cache[i])
  continue;
  if (now - ctx->sent_time_ns[i] < retry_timeout_ns) {
  still_unacked++;
  continue;
  }
  if (max_retries == 0) {
  atomic_store_explicit(&ctx->abort_flag, true, memory_order_relaxed);
  return NULL;
  }
  uint32_t _abs_seq_r = _block_base + i;
  uint16_t rport = chunk_port(ctx->sess, ctx->cfg, _abs_seq_r);
  {
  struct sockaddr_in rdest = *ctx->peer_addr;
  rdest.sin_port = htons(rport);
  mpcp_ring_slot_t rslot;
  memset(&rslot, 0, sizeof(rslot));
  rslot.seq_index = _abs_seq_r;
  rslot.ct_len    = ctx->retry_cache_lens[i];
  rslot.data_len  = ctx->retry_data_lens[i];
  rslot.flags     = ctx->retry_flags[i];
  rslot.buf       = ctx->retry_cache[i];
  memcpy(rslot.nonce, ctx->retry_nonces[i], 24);
  (void)send_chunk_packet(a->ack_sock, &rdest, ctx->sess, &rslot,
  MPCP_TYPE_DATA_CHUNK, (uint8_t)max_retries,
  false);
  ctx->sent_time_ns[i] = mpcp_now_ns();
  still_unacked++;
  }
  }
  if (still_unacked > 0) {
  struct timespec ts = { .tv_sec = 0, .tv_nsec = 100000000L };
  nanosleep(&ts, NULL);
  }
  max_retries--;
  } while (still_unacked > 0 && max_retries > 0 &&
  !atomic_load_explicit(&ctx->abort_flag, memory_order_relaxed));
  }
  return NULL;
  }
  typedef struct {
  mpcp_sender_ctx_t *ctx;
  int                sock;
  uint32_t           total_expected;
  } ack_handler_arg_t;
  static void *thread_ack_handler(void *arg)
  {
  ack_handler_arg_t *a   = arg;
  mpcp_sender_ctx_t *ctx = a->ctx;
  uint8_t  buf[MPCP_ACK_PKT_LEN + 4u];
  uint32_t deadline_ms = (uint32_t)(ctx->cfg->chunk_retry_timeout * 1000.0);
  struct timeval tv;
  tv.tv_sec  = (time_t)(deadline_ms / 1000u);
  tv.tv_usec = (suseconds_t)((deadline_ms % 1000u) * 1000u);
  (void)setsockopt(a->sock, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));
  uint32_t _blk_base = ctx->block_base;
  uint32_t _blk_size = ctx->block_size;
  while (atomic_load_explicit(&ctx->acks_received, memory_order_relaxed)
  < a->total_expected)
  {
  if (atomic_load_explicit(&ctx->abort_flag, memory_order_relaxed))
  break;
  ssize_t n = recv(a->sock, buf, sizeof(buf), 0);
  if (n < (ssize_t)MPCP_ACK_PKT_LEN) continue;
  uint32_t magic;
  memcpy(&magic, buf, 4);
  if (ntohl(magic) != MPCP_MAGIC) continue;
  if (buf[4] != MPCP_VERSION)     continue;
  if (buf[5] != MPCP_TYPE_ACK)    continue;
  uint32_t ack_seq;
  memcpy(&ack_seq, buf + 6, 4);
  ack_seq = ntohl(ack_seq);
  /* Block-window filter: only accept ACKs for this block */
  if (ack_seq < _blk_base || ack_seq >= _blk_base + _blk_size) continue;
  uint8_t expected_hash[4];
  if (mpcp_ack_hash(ctx->sess->session_key, ack_seq,
  expected_hash) != MPCP_OK) continue;
  if (memcmp(buf + 10, expected_hash, 4) != 0) continue;
  if (mpcp_dedup_accept(&ctx->ack_dedup, ack_seq)) {
  uint32_t _local = ack_seq - _blk_base;
  atomic_fetch_add_explicit(&ctx->acks_received, 1u,
  memory_order_relaxed);
  /* --- sw: SACK bitmask + RTT sample + shared base publish ------------- */
  {
  mpcp_sliding_window_t *sw = &ctx->sw;
  /* Mark this seq as received in the SACK bitmask */
  uint64_t seq64 = (uint64_t)ack_seq;
  mpcp_sw_ack_bit_set(sw, seq64);
  /* Advance recv_next */
  if (seq64 + 1u > sw->recv_next) sw->recv_next = seq64 + 1u;
  /* Capture hardware/software send timestamp for RTT if available */
  uint64_t send_ts_ns = 0u;
  if (_local < _blk_size && ctx->sent_time_ns)
      send_ts_ns = ctx->sent_time_ns[_local];
  if (send_ts_ns != 0u) {
      uint64_t rtt_ns = mpcp_now_ns() - send_ts_ns;
      /* Only publish if no sample is pending (don't overwrite un-consumed) */
      uint64_t expected_zero = 0u;
      /* CAS so we never clobber a sample the send thread hasn't consumed */
      (void)atomic_compare_exchange_strong_explicit(
          &sw->rtt_sample_ns,
          &expected_zero, rtt_ns,
          memory_order_release,
          memory_order_relaxed);
  }
  /* Advance cumulative recv_base over consecutive received seqs.
   * Clear each consumed bit so the modular slot is free for re-use. */
  while (mpcp_sw_ack_bit_test(sw, sw->recv_base)) {
      uint64_t _mb = sw->ack_mask_len * 8u;
      uint64_t _of = sw->recv_base & (_mb - 1u);
      sw->ack_mask[_of / 8u] &= (uint8_t)~(1u << (_of % 8u));
      sw->recv_base++;
  }
  /* Publish to send thread (release-store; pairs with acquire-load there) */
  atomic_store_explicit(&sw->shared_ack_base, sw->recv_base,
                        memory_order_release);
  atomic_store_explicit(&sw->shared_window_adv,
                        sw->window_size,    /* echo current window */
                        memory_order_relaxed);
  }
  /* -------------------------------------------------------------------- */
  /* Clear retry_cache: sentinel that retry phase uses to confirm ACK */
  if (_local < _blk_size && ctx->retry_cache && ctx->retry_cache[_local]) {
  sodium_memzero(ctx->retry_cache[_local], ctx->retry_cache_lens[_local]);
  free(ctx->retry_cache[_local]);
  ctx->retry_cache[_local]      = NULL;
  ctx->retry_cache_lens[_local] = 0;
  atomic_store_explicit(&ctx->sent_flag[_local], false, memory_order_relaxed);
  }
  }
  }
  return NULL;
  }
  int mpcp_sender_run(const mpcp_config_t      *cfg,
  mpcp_session_t           *sess,
  const struct sockaddr_in *peer_addr,
  const char               *file_path)
  {
  if (!cfg || !sess || !peer_addr || !file_path) return MPCP_ERR_PARAM;
  int file_fd = open(file_path, O_RDONLY);
  if (file_fd < 0) return MPCP_ERR_IO;
  struct stat st;
  if (fstat(file_fd, &st) < 0) { close(file_fd); return MPCP_ERR_IO; }
  size_t file_size = (size_t)st.st_size;
  if (file_size == 0) { close(file_fd); return MPCP_ERR_PARAM; }
  size_t probe_sz = file_size < 65536u ? file_size : 65536u;
  uint8_t *probe  = malloc(probe_sz);
  if (!probe) { close(file_fd); return MPCP_ERR_ALLOC; }
  if (read(file_fd, probe, probe_sz) != (ssize_t)probe_sz) {
  free(probe); close(file_fd); return MPCP_ERR_IO;
  }
  if (lseek(file_fd, 0, SEEK_SET) < 0) {
  free(probe); close(file_fd); return MPCP_ERR_IO;
  }
  mpcp_chunk_plan_t plan;
  memset(&plan, 0, sizeof(plan));
  mpcp_chunker_detect_compressibility(probe, probe_sz, &plan);
  free(probe);
  if (!plan.skip_compression) {
  /* OOM-FIX: cap compressibility test at 1MB regardless of file_size */
  static const size_t PROBE_CAP = 1u << 20;
  size_t probe_sz2 = (file_size < PROBE_CAP) ? file_size : PROBE_CAP;
  size_t bound = ZSTD_compressBound(probe_sz2);
  uint8_t *tmp = malloc(bound);
  uint8_t *raw = malloc(probe_sz2);
  if (tmp && raw) {
  if (pread(file_fd, raw, probe_sz2, 0) == (ssize_t)probe_sz2) {
  size_t clen = ZSTD_compress(tmp, bound, raw, probe_sz2, cfg->zstd_level);
  if (ZSTD_isError(clen) ||
  (double)clen / (double)probe_sz2 > 0.95) {
  plan.skip_compression = true;
  }
  }
  }
  free(raw); free(tmp);
  if (lseek(file_fd, 0, SEEK_SET) < 0) { close(file_fd); return MPCP_ERR_IO; }
  }
  int rc = mpcp_chunker_plan(file_size, cfg->chunk_pad_size,
  plan.skip_compression, &plan);
  if (rc != MPCP_OK) { close(file_fd); return rc; }
  uint32_t ghost_seqs[64];
  uint32_t ghost_count = 0;
  if (cfg->ghost_chunks_enabled) {
  (void)mpcp_ghost_map(sess->session_key,
  plan.n_chunks,
  cfg->ghost_chunk_min,
  cfg->ghost_chunk_max,
  ghost_seqs, &ghost_count);
