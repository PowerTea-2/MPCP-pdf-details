  P3_CHECK("T-P3-06g buf matches",    out->buf[0]    == 0xBB);
  mpcp_ring_release(&ring, out);
  }
  P3_CHECK("T-P3-06h empty after release", mpcp_ring_consume(&ring) == NULL);
