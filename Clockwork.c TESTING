  uint32_t _rblk_base    = 0;
  uint32_t _rn_total     = n_chunks;
  uint32_t _rn_blocks    = (_rn_total + MAX_BLOCK_CHUNKS - 1u) / MAX_BLOCK_CHUNKS;
  uint32_t _total_written = 0;
