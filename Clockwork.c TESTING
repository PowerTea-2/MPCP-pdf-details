  }
  static void test_blink_engine(void)
  {
  puts("T-BLINK  Blink Engine unit tests");
  {
  const uint64_t INTERVAL_NS = 10000000ULL;
  blink_pacer_t  pacer;
  uint64_t       origin = mpcp_now_ns() + 5000000ULL;
  blink_pacer_init(&pacer, INTERVAL_NS, origin);
  uint64_t t0 = mpcp_now_ns();
  blink_pacer_wait(&pacer);
  blink_pacer_wait(&pacer);
  uint64_t elapsed = mpcp_now_ns() - t0;
  bool ok = (elapsed >= 13000000ULL && elapsed <= 30000000ULL);
  P3_CHECK("T-BLINK-01a pacer: two slots in expected time range", ok);
  if (g_debug_stealth)
  fprintf(stderr, "  [blink-test] pacer elapsed=%.1fms\n",
  (double)elapsed / 1e6);
  }
  {
  blink_window_t w;
  blink_window_init(&w);
  for (int i = 0; i < 10; i++) blink_window_record(&w, true);
  for (int i = 0; i < 5;  i++) blink_window_record(&w, false);
  double miss = blink_window_miss_rate(&w);
  P3_CHECK("T-BLINK-02a window miss rate correct",
  miss > 0.32 && miss < 0.35);
  for (uint32_t i = 0; i < BLINK_WINDOW_SIZE; i++)
  blink_window_record(&w, true);
  double miss2 = blink_window_miss_rate(&w);
  P3_CHECK("T-BLINK-02b window evicts old entries (all hits → 0% miss)",
  miss2 < 0.01);
  P3_CHECK("T-BLINK-02c window count capped at BLINK_WINDOW_SIZE",
  w.count == BLINK_WINDOW_SIZE);
  }
  {
  mpcp_session_t sess;
  memset(&sess, 0, sizeof(sess));
  sess.drift_coefficient = 1.0;
  randombytes_buf(sess.session_nonce, MPCP_SESSION_NONCE_LEN);
  randombytes_buf(sess.session_key,   MPCP_SESSION_KEY_LEN);
  /* keystream is O(1) on-the-fly — no allocation needed */
  mpcp_config_t cfg;
  mpcp_config_defaults(&cfg);
  cfg.port_hop_interval = 1;
  uint16_t p1 = blink_hop_port(&sess, &cfg, 5);
  uint16_t p2 = blink_hop_port(&sess, &cfg, 5);
  P3_CHECK("T-BLINK-03a hop_port deterministic for same chunk", p1 == p2);
  uint16_t p3 = blink_hop_port(&sess, &cfg, 6);
  bool diff = (p1 != p3);
  P3_CHECK("T-BLINK-03b hop_port varies across chunks", diff);
  bool in_range = (p1 >= cfg.port_base &&
  p1 <  cfg.port_base + cfg.port_range);
  P3_CHECK("T-BLINK-03c hop_port within port_base..port_base+range", in_range);
  cfg.port_hop_interval = 4;
  uint16_t h0 = blink_hop_port(&sess, &cfg, 0);
  uint16_t h1 = blink_hop_port(&sess, &cfg, 1);
  uint16_t h2 = blink_hop_port(&sess, &cfg, 2);
  uint16_t h3 = blink_hop_port(&sess, &cfg, 3);
  uint16_t h4 = blink_hop_port(&sess, &cfg, 4);
  P3_CHECK("T-BLINK-03d hop_interval=4: chunks 0-3 same port",
  h0 == h1 && h1 == h2 && h2 == h3);
  P3_CHECK("T-BLINK-03e hop_interval=4: chunk 4 differs from chunks 0-3",
  h4 != h0);
  /* no keystream to free — wipe key material only */
  sodium_memzero(sess.session_key, MPCP_SESSION_KEY_LEN);
  }
  {
  mpcp_session_t sess;
  memset(&sess, 0, sizeof(sess));
  sess.blink_interval_ns = 10000000ULL;
  sess.blink_origin_ns   = 1000000000ULL;
  sess.clock_offset_ns   = 0;
  uint64_t t0 = blink_arrival_time(&sess, 0);
  uint64_t t5 = blink_arrival_time(&sess, 5);
  bool t0_ok = (t0 == 1005000000ULL);
  P3_CHECK("T-BLINK-04a arrival_time seq=0 correct", t0_ok);
  bool t5_ok = (t5 == 1055000000ULL);
  P3_CHECK("T-BLINK-04b arrival_time seq=5 correct", t5_ok);
  sess.clock_offset_ns = 2000000LL;
  uint64_t t0_pos = blink_arrival_time(&sess, 0);
  P3_CHECK("T-BLINK-04c positive offset: arrival shifts later in receiver clock",
  t0_pos == 1005000000ULL + 2000000ULL);
  sess.clock_offset_ns = -2000000LL;
  uint64_t t0_neg = blink_arrival_time(&sess, 0);
  P3_CHECK("T-BLINK-04d negative offset: arrival shifts earlier",
  t0_neg == 1005000000ULL - 2000000ULL);
  }
  {
  int server_fd = socket(AF_INET, SOCK_DGRAM, 0);
  P3_CHECK("T-BLINK-05 socket creation", server_fd >= 0);
  if (server_fd >= 0) {
  struct sockaddr_in sa;
  memset(&sa, 0, sizeof(sa));
  sa.sin_family      = AF_INET;
  sa.sin_addr.s_addr = htonl(INADDR_LOOPBACK);
  sa.sin_port        = 0;
  bind(server_fd, (struct sockaddr *)&sa, sizeof(sa));
  uint8_t buf[64];
  struct sockaddr_in from;
  socklen_t fl = sizeof(from);
  uint64_t target = mpcp_now_ns() + 2000000ULL;
  uint64_t t_before = mpcp_now_ns();
  ssize_t r = blink_recv_window(server_fd, buf, sizeof(buf),
  target, 5000000ULL, &from, &fl);
  uint64_t t_after = mpcp_now_ns();
  double elapsed_ms = (double)(t_after - t_before) / 1e6;
  P3_CHECK("T-BLINK-05a guard band timeout returns -1", r == -1);
  P3_CHECK("T-BLINK-05b guard band minimum duration >=5ms",
  elapsed_ms >= 4.5);
  P3_CHECK("T-BLINK-05c guard band maximum duration <15ms",
  elapsed_ms < 15.0);
  close(server_fd);
  }
  }
  {
  mpcp_session_t sess;
  memset(&sess, 0, sizeof(sess));
  sess.blink_interval_ns = 10000000ULL;
  sess.blink_origin_ns   = 500000000ULL;
  uint64_t expected_sched =
  sess.blink_origin_ns + 3ULL * sess.blink_interval_ns;
  bool formula_ok = (expected_sched == 530000000ULL);
  P3_CHECK("T-BLINK-06a scheduled_time formula: origin + seq * interval",
  formula_ok);
  uint64_t sched_be = __builtin_bswap64(expected_sched);
  uint8_t encoded[8];
  memcpy(encoded, &sched_be, 8);
  uint64_t decoded_be;
  memcpy(&decoded_be, encoded, 8);
  uint64_t decoded = __builtin_bswap64(decoded_be);
  P3_CHECK("T-BLINK-06b BE round-trip preserves scheduled_time",
  decoded == expected_sched);
  }
  {
  mpcp_session_t sess;
  memset(&sess, 0, sizeof(sess));
  mpcp_config_t cfg;
  mpcp_config_defaults(&cfg);
  cfg.blink_interval_us = 0;
  double fake_rtts[5] = { 10.0, 11.0, 10.5, 9.5, 10.0 };
  double ewma = 10.2;
  blink_calibrate_from_rtt(&sess, &cfg, fake_rtts, 5, ewma);
  bool interval_ok = (sess.blink_interval_ns >= 5000000ULL &&
  sess.blink_interval_ns <= 200000000ULL);
  P3_CHECK("T-BLINK-07a calibrated interval within valid range",
  interval_ok);
  cfg.blink_interval_us = 25000;
  blink_calibrate_from_rtt(&sess, &cfg, fake_rtts, 5, ewma);
  bool override_ok = (sess.blink_interval_ns == 25000000ULL);
  P3_CHECK("T-BLINK-07b explicit blink_interval_us respected", override_ok);
  bool origin_future = (sess.blink_origin_ns > mpcp_now_ns());
  P3_CHECK("T-BLINK-07c blink_origin_ns set in the future", origin_future);
  }
