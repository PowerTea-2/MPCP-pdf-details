  for (uint32_t i = 0; i < n; i++) {
      uint32_t seq = a->block_seqs[i];
      fds[i] = open_udp_socket_on_port(chunk_port(sess, cfg, seq));
  }
  uint64_t deadline_ns = mpcp_now_ns()
                       + (uint64_t)cfg->chunk_retry_timeout * 3ULL * 1000000000ULL
                       + 30000000000ULL;
  bool *got2 = calloc(n, sizeof(bool));
  if (!got2) {
      for (uint32_t i = 0; i < n; i++) if (fds[i] >= 0) close(fds[i]);
      free(fds); free(pkt);
      atomic_store_explicit(&ctx->t1_done, true, memory_order_release);
      return NULL;
  }
  while (received < n && mpcp_now_ns() < deadline_ns) {
      if (atomic_load_explicit(&ctx->abort_flag, memory_order_relaxed)) break;
      bool any = false;
      for (uint32_t i = 0; i < n; i++) {
          /*
           * FIX 3: Guard on fds[i]<0 only.  A socket whose "own" chunk
           * is already received must stay in the poll loop — it may be
           * the sole socket for a colliding port and still has other
           * chunks' packets to deliver.
           */
          if (fds[i] < 0) continue;

          struct sockaddr_in fsrc;
          socklen_t fsl = sizeof(fsrc);
          ssize_t nb = recvfrom(fds[i], pkt, pkt_max, MSG_DONTWAIT,
                                (struct sockaddr *)&fsrc, &fsl);
          if (nb < (ssize_t)MPCP_DATA_HDR_OFFSET) continue;

          /* Packet header validation */
          uint32_t m2; memcpy(&m2, pkt, 4);
          if (ntohl(m2) != MPCP_MAGIC || pkt[4] != MPCP_VERSION) continue;
          if (pkt[5] != MPCP_TYPE_DATA_CHUNK &&
              pkt[5] != MPCP_TYPE_GHOST_CHUNK) continue;

          uint32_t ps2; memcpy(&ps2, pkt + 6, 4); ps2 = ntohl(ps2);

          /*
           * FIX 1: Reverse-map ps2 → the correct index in block_seqs[].
           *
           * We cannot assume ps2 == block_seqs[i].  When a port collision
           * occurs the victim's packet arrives on socket i even though
           * ps2 corresponds to a different chunk j.  Scan block_seqs[]
           * to find the true owner; skip if unknown or already received.
           */
          uint32_t mapped_j = n; /* sentinel: not found */
          for (uint32_t j = 0; j < n; j++) {
              if (a->block_seqs[j] == ps2 && !got2[j]) {
                  mapped_j = j;
                  break;
              }
          }
          if (mapped_j == n) continue; /* seq not in this block or already done */

          /* Ghost packet: credit the MAPPED index, not i */
          bool isg2 = false;
          for (uint32_t g = 0; g < ctx->ghost_count; g++)
              if (ctx->ghost_seqs[g] == ps2) { isg2 = true; break; }
          if (isg2) {
              /*
               * FIX 2: Do NOT close fds[i] here.  Another chunk sharing
               * this port may still need this socket.
               */
              got2[mapped_j] = true; received++; any = true;
              continue;
          }

          /* Dedup is keyed on ps2 (wire seq), correct for all collision cases */
          if (!mpcp_dedup_accept(&ctx->dedup, ps2)) continue;

          /* Publish ciphertext to the decryption ring */
          mpcp_ring_slot_t *sl2 = mpcp_ring_claim(&ctx->ring0);
          sl2->seq_index = ps2;
          sl2->flags     = pkt[11];
          size_t ct2 = (size_t)(nb - (ssize_t)MPCP_DATA_HDR_OFFSET);
          if (ct2 > sl2->buf_capacity) ct2 = sl2->buf_capacity;
          memcpy(sl2->buf, pkt + MPCP_DATA_HDR_OFFSET, ct2);
          sl2->ct_len   = ct2;
          sl2->data_len = ntohl(*(const uint32_t *)(const void *)(pkt + 12));
          memcpy(sl2->nonce, pkt + 16, 24);
          mpcp_ring_publish(&ctx->ring0, sl2);

          /* ACK — sent back on the socket that received this chunk */
          { mpcp_ack_pkt_t a2; memset(&a2, 0, sizeof(a2));
            uint32_t am2 = htonl(MPCP_MAGIC); memcpy(&a2.hdr.magic, &am2, 4);
            a2.hdr.version = MPCP_VERSION; a2.hdr.type = MPCP_TYPE_ACK;
            uint32_t as2 = htonl(ps2); memcpy(&a2.ack_seq, &as2, 4);
            uint8_t ah2[4];
            if (mpcp_ack_hash(sess->session_key, ps2, ah2) == MPCP_OK)
                memcpy(&a2.ack_hash, ah2, 4);
            a2.sack_bitmap = 0;
            randombytes_buf(a2.padding, sizeof(a2.padding));
            sendto(fds[i], &a2, sizeof(a2), 0,
                   (const struct sockaddr *)&fsrc, fsl); }

          /* Progress display */
          { uint32_t dd = 0;
            for (uint32_t _d = 0; _d < n; _d++) if (got2[_d]) dd++;
            fprintf(stderr, "\r  [%u/%u]   ", dd + 1, ctx->plan.n_chunks);
            fflush(stderr); }

          /*
           * FIX 1+2: Mark the MAPPED index (not i).
           * FIX 2:   Leave fds[i] open — collision victims sharing this
           *          port still need it.  All cleanup happens below.
           */
          got2[mapped_j] = true; received++; any = true;
      }
      if (!any) { struct timespec ts2 = {0, 1000000L}; nanosleep(&ts2, NULL); }
  }
  /*
   * Post-loop cleanup: close every open socket exactly once.
   * Because collision victims have fds[j]=-1 and winners have unique fd
   * values, this loop never double-closes.
   */
  free(got2);
  for (uint32_t i = 0; i < n; i++) if (fds[i] >= 0) close(fds[i]);
  free(fds);
  }
  free(pkt);
  atomic_store_explicit(&ctx->t1_done, true, memory_order_release);
  return NULL;
  }
  typedef struct { mpcp_receiver_ctx_t *ctx; } verifier_arg_t;
  static void *thread_verifier(void *arg)
  {
  verifier_arg_t      *a   = arg;
  mpcp_receiver_ctx_t *ctx = a->ctx;
  for (;;) {
  mpcp_ring_slot_t *in = mpcp_ring_consume(&ctx->ring0);
  if (!in) {
  if (atomic_load_explicit(&ctx->t1_done, memory_order_acquire)) break;
  if (atomic_load_explicit(&ctx->abort_flag, memory_order_relaxed)) break;
  continue;   /* condvar ring already waited 1ms */
  }
  uint32_t seq = in->seq_index;
  bool is_ghost = false;
  for (uint32_t g = 0; g < ctx->ghost_count; g++) {
  if (ctx->ghost_seqs[g] == seq) { is_ghost = true; break; }
  }
  if (is_ghost) {
  sodium_memzero(in->buf, in->ct_len);
  mpcp_ring_release(&ctx->ring0, in);
  atomic_fetch_add_explicit(&ctx->chunks_verified, 1u, memory_order_relaxed);
  continue;
  }
