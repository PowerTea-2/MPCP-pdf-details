  if (_rblk_sz > MAX_BLOCK_CHUNKS) _rblk_sz = MAX_BLOCK_CHUNKS;
  atomic_store_explicit(&ctx.chunks_verified, 0u, memory_order_relaxed);
  atomic_store_explicit(&ctx.t1_done, false, memory_order_relaxed);
  atomic_store_explicit(&ctx.t2_done, false, memory_order_relaxed);
  atomic_store_explicit(&ctx.t3_done, false, memory_order_relaxed);
  /* Clear block store */
  for (uint32_t _ci = 0; _ci < _rblk_sz; _ci++) {
  if (chunk_store[_ci]) {
  sodium_memzero(chunk_store[_ci], chunk_lens[_ci]);
  free(chunk_store[_ci]);
  chunk_store[_ci] = NULL;
  }
  chunk_lens[_ci]  = 0;
  chunk_ready[_ci] = false;
  }
  mpcp_dedup_init(&ctx.dedup);
  uint32_t _ri        = _rblk_base / MAX_BLOCK_CHUNKS;
  ctx.block_ghost_start = (uint32_t)((uint64_t)ghost_count * _ri / _rn_blocks);
  ctx.block_ghost_end   = (uint32_t)((uint64_t)ghost_count * (_ri+1u) / _rn_blocks);
  ctx.block_base     = _rblk_base;
  ctx.block_size     = _rblk_sz;
  ctx.plan.n_chunks  = _rblk_sz;
  ctx.next_write_seq = 0;
  uint32_t expected_in_block = _rblk_sz + (ctx.block_ghost_end - ctx.block_ghost_start);
  uint32_t *block_seqs = malloc(expected_in_block * sizeof(uint32_t));
  if (!block_seqs) { rc = MPCP_ERR_ALLOC; goto cleanup_r2; }
  {
  uint32_t bsi = 0;
  uint32_t g_idx = ctx.block_ghost_start;
  for (uint32_t i = 0; i < _rblk_sz; i++) {
  block_seqs[bsi++] = _rblk_base + i;
  if (cfg->ghost_chunks_enabled && g_idx < ctx.block_ghost_end) {
  block_seqs[bsi++] = ghost_seqs[g_idx++];
  }
  }
  while (g_idx < ctx.block_ghost_end) {
  block_seqs[bsi++] = ghost_seqs[g_idx++];
  }
  }
  recv_t1_arg_t  t1_arg = { &ctx, expected_in_block, block_seqs, catch_ms };
  verifier_arg_t t2_arg = { &ctx };
  decrypt_arg_t  t3_arg = { &ctx };
  writer_arg_t   t4_arg = { &ctx, use_decomp };
  pthread_t t1, t2, t3, t4;
  pthread_create(&t1, NULL, thread_receiver_t1, &t1_arg);
  pthread_create(&t2, NULL, thread_verifier,    &t2_arg);
  pthread_create(&t3, NULL, thread_decryptor,   &t3_arg);
  pthread_create(&t4, NULL, thread_writer,      &t4_arg);
  pthread_join(t1, NULL);
  pthread_join(t2, NULL);
  pthread_join(t3, NULL);
  pthread_join(t4, NULL);
  free(block_seqs);
  block_seqs = NULL;
  if (ctx.next_write_seq < _rblk_sz) {
  fprintf(stderr, "[block-sync] receiver: block %u incomplete %u/%u chunks\n",
  _rblk_base / MAX_BLOCK_CHUNKS, ctx.next_write_seq, _rblk_sz);
  rc = MPCP_ERR_TIMEOUT;
  unlink(out_path);
  goto cleanup_r2;
  }
  _total_written += _rblk_sz;
  fprintf(stderr, "[block-sync] receiver: block %u/%u flushed (%u chunks)\n",
  _rblk_base / MAX_BLOCK_CHUNKS + 1u,
  (_rn_total + MAX_BLOCK_CHUNKS - 1u) / MAX_BLOCK_CHUNKS, _rblk_sz);
  _rblk_base += _rblk_sz;
  }
  if (_total_written == n_chunks) {
  rc = MPCP_OK;
  resume_clear(out_path);
  } else if (rc == MPCP_OK) {
  rc = MPCP_ERR_TIMEOUT;
  }
  /* keystream was O(1) on-the-fly — nothing to free */
  cleanup_r2:
  mpcp_ring_destroy(&ctx.ring2);
  cleanup_r1:
  mpcp_ring_destroy(&ctx.ring1);
  cleanup_r0:
  mpcp_ring_destroy(&ctx.ring0);
  cleanup:
  for (uint32_t i = 0; i < MAX_BLOCK_CHUNKS; i++) {
  if (chunk_store[i]) {
  sodium_memzero(chunk_store[i], chunk_lens[i]);
  free(chunk_store[i]);
  }
  }
  free(chunk_store);
  free(chunk_lens);
  free(chunk_ready);
  if (ctx.decrypt_buf) {
  sodium_memzero(ctx.decrypt_buf, ctx.decrypt_buf_sz);
  free(ctx.decrypt_buf);
  }
  close(out_fd);
  return rc;
  }
