  uint8_t ka[32], kb[32]; uint16_t pa, pb;
  mpcp_get_chunk_params(&sess1, &cfg, 0, ka, &pa);
  mpcp_get_chunk_params(&sess3, &cfg, 0, kb, &pb);
  bool different = (sodium_memcmp(ka, kb, 32) != 0);
