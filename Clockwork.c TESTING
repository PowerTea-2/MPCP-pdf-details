/* ---------------------------------------------------------------------------
 * q32_t  —  signed Q16.16 fixed-point scalar (FPU-free Kalman arithmetic)
 *
 *   Bit layout:  [31..16] integer part  |  [15..0] fractional part
 *   Range:       ±32767.99998...
 *   Resolution:  ~1.526e-5  (1/65536)
 * --------------------------------------------------------------------------*/
typedef int32_t q32_t;

#define Q32_FROM_INT(x)  ((q32_t)((int32_t)(x) << 16))
#define Q32_ONE          Q32_FROM_INT(1)
#define Q32_MUL(a, b)   ((q32_t)(((int64_t)(a) * (int64_t)(b)) >> 16))
#define Q32_DIV(a, b)   ((q32_t)(((int64_t)(a) << 16) / (int64_t)(b)))

/* ---------------------------------------------------------------------------
 * mpcp_sliding_window_t — 64-bit Selective-Repeat sliding window
 *
 * Memory layout — four 64-byte cache lines, zero cross-line false sharing:
 *
 *   Line 0  [  0.. 63]  Sender-private hot path  (send thread only)
 *   Line 1  [ 64..127]  ACK-receiver hot path    (ACK thread only)
 *   Line 2  [128..191]  Shared atomics            (both threads, RMW)
 *   Line 3  [192..255]  Kalman filter state       (send thread only)
 * --------------------------------------------------------------------------*/
typedef struct mpcp_sliding_window {

    /* -----------------------------------------------------------------------
     * LINE 0 — Sender-private hot path                              [0..63]
     * Written exclusively by the send thread; ACK thread NEVER touches these.
     * ----------------------------------------------------------------------- */
    alignas(64)

    /** Sequence number of the oldest unacknowledged segment (SND.UNA). */
    uint64_t    send_base;

    /** Next sequence number to assign to an outgoing segment (SND.NXT). */
    uint64_t    send_next;

    /** Negotiated receive-window advertisement (in segments). */
    uint64_t    window_size;

    /** Number of segments currently in-flight (sent, not yet ACK'd). */
    uint64_t    inflight;

    /** Monotonic timestamp (ns) of the most recent segment transmission. */
    uint64_t    last_send_ns;

    /** Current retransmission timeout in nanoseconds (updated by Kalman). */
    uint64_t    retx_timeout_ns;

    /** Token-bucket: remaining send credits in bytes (rate limiter). */
    int64_t     token_bucket_credits;

    /** Token refill rate in bytes-per-nanosecond (Q32 fixed-point). */
    q32_t       token_refill_rate;

    uint8_t     _pad0[4];

    /* -----------------------------------------------------------------------
     * LINE 1 — ACK-receiver hot path                              [64..127]
     * Written exclusively by the ACK thread; send thread NEVER touches these.
     * ----------------------------------------------------------------------- */
    alignas(64)

    /** Cumulative ACK number: all seqnos below this are confirmed received. */
    uint64_t    recv_base;

    /** Highest sequence number seen + 1 (RCV.NXT equivalent). */
    uint64_t    recv_next;

    /**
     * Selective-ACK bitmask pointer.
     *
     * Bit  k  in ack_mask[]  corresponds to sequence number (recv_base + k).
     * A set bit indicates the segment has been received out-of-order.
     * Allocated externally; length = ceil(window_size / 8) bytes.
     */
    uint8_t    *ack_mask;

    /** Length of the ack_mask allocation in bytes. */
    uint64_t    ack_mask_len;

    /** Monotonic timestamp (ns) of the most recently processed ACK. */
    uint64_t    last_ack_ns;

    /** Duplicate-ACK counter (fast-retransmit trigger at threshold 3). */
    uint32_t    dup_ack_count;

    /** Highest SACK block right-edge seen this RTT (for reorder detection). */
    uint32_t    sack_high_water;

    uint8_t     _pad1[8];

    /* -----------------------------------------------------------------------
     * LINE 2 — Shared atomics (both threads perform RMW here)    [128..191]
     * All fields are _Atomic; MESI thrash is contained to this one line,
     * and never invalidates the private lines above.
     * ----------------------------------------------------------------------- */
    alignas(64)

    /**
     * ACK'd base published by the ACK thread; consumed by the send thread
     * to advance send_base and release window credits.
     * Ordering: ACK thread release-stores; send thread acquire-loads.
     */
    _Atomic uint64_t    shared_ack_base;

    /**
     * Window credit advertisement written by ACK thread, read by send thread.
     * Represents the receiver's current advertised window in segments.
     */
    _Atomic uint64_t    shared_window_adv;

    /**
     * Packed protocol state machine + control flags.
     *
     * Bits [7..0]   : connection state  (CLOSED/SLOW_START/CONG_AVOID/…)
     * Bits [15..8]  : event flags       (FLAG_FAST_RETX | FLAG_ECN | …)
     * Bits [31..16] : reserved
     */
    _Atomic uint32_t    state_flags;

    /**
     * Measured raw RTT sample in nanoseconds, published by the ACK thread
     * after each timestamped echo, consumed by the Kalman update on the
     * send thread.
     */
    _Atomic uint64_t    rtt_sample_ns;

    /**
     * Generation counter for seqlock-style window resets.
     * Odd  → reset in progress (send thread must pause).
     * Even → stable.
     */
    _Atomic uint32_t    generation;

    /* 4 bytes compiler padding before rtt_sample_ns (8-byte align) plus
     * 24 bytes before kf_rtt_estimate (alignas(64)) = 28 bytes total.
     * Declaring them all explicitly removes every invisible compiler gap. */
    uint8_t             _pad2[28];

    /* -----------------------------------------------------------------------
     * LINE 3 — 1-D Kalman filter state (RTT estimator)          [192..255]
     *
     * All quantities are Q16.16 fixed-point (q32_t), units = milliseconds.
     * ms keeps every value inside the ±32767 integer range of Q16.16:
     *   min RTT  ≈ 0.001 ms  (fits; Q16.16 resolution ≈ 1.5e-5)
     *   max RTO  ≈ 30 000 ms (30 s — well below INT32_MAX/65536 ≈ 32767)
     *
     *   Predict:  x̂⁻ = x̂               (constant-velocity model, F = 1)
     *             P⁻  = P + Q
     *
     *   Update:   K   = P⁻ / (P⁻ + R)
     *             x̂  = x̂⁻ + K · (z − x̂⁻)
     *             P   = (1 − K) · P⁻
     *
     * Kept on a private cache line so the update loop runs with zero
     * cross-thread coherence traffic.
     * ----------------------------------------------------------------------- */
    alignas(64)

    /** x̂  — posterior state estimate: smoothed RTT in ms (Q16.16). */
    q32_t   kf_rtt_estimate;

    /** P   — posterior error covariance (dimensionless ratio, Q16.16). */
    q32_t   kf_error_cov;

    /** Q   — process noise covariance: models RTT drift (Q16.16). */
    q32_t   kf_process_noise;

    /** R   — measurement noise covariance: models timestamp jitter (Q16.16). */
    q32_t   kf_meas_noise;

    /** K   — Kalman gain from the most recent update step (Q16.16). */
    q32_t   kf_gain;

    /** Innovation z − x̂⁻ from the most recent measurement (Q16.16, ms). */
    q32_t   kf_innovation;

    /**
     * σ²_rtt — smoothed RTT variance used to set retx_timeout_ns:
     *   RTO = x̂ + 4·√(σ²_rtt)   (mirrors RFC 6298 with fixed-point sqrt).
     */
    q32_t   kf_rtt_variance;

    /**
     * Minimum RTT ever observed (Q16.16, ms).
     * Lower-bound sanity clamp on x̂ to resist ACK compression.
     */
    q32_t   kf_rtt_min;

    /** Number of Kalman update cycles executed (diagnostics / warm-up guard). */
    uint64_t    kf_update_count;

    uint8_t     _pad3[24];

} mpcp_sliding_window_t;

_Static_assert(sizeof(mpcp_sliding_window_t) == 256,
               "mpcp_sliding_window_t must be exactly 256 bytes (4 cache lines)");
_Static_assert(alignof(mpcp_sliding_window_t) == 64,
               "mpcp_sliding_window_t must be 64-byte aligned");
_Static_assert(offsetof(mpcp_sliding_window_t, recv_base)       ==  64, "LINE 1 drift");
_Static_assert(offsetof(mpcp_sliding_window_t, shared_ack_base) == 128, "LINE 2 drift");
_Static_assert(offsetof(mpcp_sliding_window_t, kf_rtt_estimate) == 192, "LINE 3 drift");

