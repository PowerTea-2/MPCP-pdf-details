uint16_t seq,
double *rtt_ms_out,
uint64_t *t_send_raw_out,
uint64_t *t_recv_raw_out)
{
mpcp_cal_pkt_t ping;
build_ping(&ping, seq, session_nonce);
uint8_t wire[MPCP_CAL_WIRE_BUF];
size_t wire_len = sizeof(ping);
if (cfg->disguise_calibration) {
wire_len = mpcp_disguise_wrap((const uint8_t *)&ping, sizeof(ping),
wire, sizeof(wire), cfg->disguise_protocol);
if (wire_len == 0) return MPCP_ERR_PROTO;
} else {
memcpy(wire, &ping, sizeof(ping));
}
uint64_t t0 = mpcp_now_raw_ns();
if (sendto(sock, wire, wire_len, 0, (const struct sockaddr *)peer, sizeof(*peer)) < 0)
return MPCP_ERR_IO;
uint8_t rx[MPCP_CAL_WIRE_BUF];
struct sockaddr_in from;
socklen_t fromlen = sizeof(from);
ssize_t n = recvfrom(sock, rx, sizeof(rx), 0, (struct sockaddr *)&from, &fromlen);
uint64_t t1 = mpcp_now_raw_ns();
if (n < 0) return (errno == EAGAIN || errno == EWOULDBLOCK) ? MPCP_ERR_TIMEOUT : MPCP_ERR_IO;
if (from.sin_addr.s_addr != peer->sin_addr.s_addr) return MPCP_ERR_TIMEOUT;
size_t payload_len = (size_t)n;
if (cfg->disguise_calibration) {
payload_len = mpcp_disguise_unwrap(rx, (size_t)n, rx, sizeof(rx), cfg->disguise_protocol);
if (payload_len == 0) return MPCP_ERR_PROTO;
}
uint64_t echoed_send_ts = 0;
if (!parse_pong(rx, payload_len, seq, &echoed_send_ts)) return MPCP_ERR_PROTO;
(void)echoed_send_ts;
double rtt_ms = (double)(t1 - t0) / 1e6;
if (rtt_ms <= 0.01 || rtt_ms > 5000.0) return MPCP_ERR_TIMEOUT;
*rtt_ms_out = rtt_ms;
if (t_send_raw_out) *t_send_raw_out = t0;
if (t_recv_raw_out) *t_recv_raw_out = t1;
return MPCP_OK;
}

static uint16_t calib_ghost_port(const mpcp_config_t *cfg, const mpcp_session_t *sess)
{
if (cfg->port_range == 0) return cfg->port_base;
uint8_t digest[4];
crypto_generichash_state st;
crypto_generichash_init(&st, NULL, 0, sizeof(digest));
crypto_generichash_update(&st, sess->session_nonce, MPCP_SESSION_NONCE_LEN);
crypto_generichash_update(&st, (const unsigned char *)"cal-ghost", 9);
crypto_generichash_final(&st, digest, sizeof(digest));
uint32_t v = ((uint32_t)digest[0] << 24) | ((uint32_t)digest[1] << 16)
| ((uint32_t)digest[2] << 8)  | ((uint32_t)digest[3]);
return (uint16_t)(cfg->port_base + (v % cfg->port_range));
}

int mpcp_calibrate(const mpcp_config_t    *cfg,
const mpcp_session_t   *sess,
const struct sockaddr_in *peer_addr,
mpcp_rtt_result_t      *result_out,
mpcp_calib_t           *calib_out)
{
if (!cfg || !sess || !peer_addr || !result_out || !calib_out) return MPCP_ERR_PARAM;
memset(calib_out, 0, sizeof(*calib_out));
int sock = cal_socket_open();
if (sock < 0) return MPCP_ERR_IO;
struct timeval tv = { .tv_sec = 0, .tv_usec = 200000 };
(void)setsockopt(sock, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));

/* Phase 1: 150-ping jitter profiling with IQR outlier reject */
enum { PHASE1_TARGET = 150, PHASE1_MAX_ATTEMPTS = 300 };
double raw_rtts[PHASE1_TARGET];
size_t raw_n = 0;
for (uint16_t seq = 1; seq <= PHASE1_MAX_ATTEMPTS && raw_n < PHASE1_TARGET; seq++) {
double rtt_ms = 0.0;
if (cal_ping_once_raw(sock, cfg, peer_addr, sess->session_nonce, seq, &rtt_ms, NULL, NULL) == MPCP_OK)
raw_rtts[raw_n++] = rtt_ms;
}
if (raw_n < 30) { close(sock); return MPCP_ERR_TIMEOUT; }
calib_out->samples_sent = (uint32_t)raw_n;
double sorted[PHASE1_TARGET];
memcpy(sorted, raw_rtts, raw_n * sizeof(double));
insertion_sort_double(sorted, raw_n);
double q1 = percentile_sorted(sorted, raw_n, 0.25);
double q3 = percentile_sorted(sorted, raw_n, 0.75);
double iqr = q3 - q1;
double upper = q3 + 1.5 * iqr;
double filt[PHASE1_TARGET];
size_t fn = 0;
for (size_t i = 0; i < raw_n; i++) {
if (raw_rtts[i] <= upper) filt[fn++] = raw_rtts[i];
}
if (fn < 10) { close(sock); return MPCP_ERR_TIMEOUT; }
double mean = 0.0;
for (size_t i = 0; i < fn; i++) mean += filt[i];
mean /= (double)fn;
double var = 0.0;
for (size_t i = 0; i < fn; i++) {
double d = filt[i] - mean;
var += d * d;
}
var = (fn > 1) ? (var / (double)(fn - 1)) : 0.0;
calib_out->stable_mean_rtt_ms = mean;
calib_out->jitter_variance_ms2 = var;
calib_out->samples_kept = (uint32_t)fn;

/* Phase 2: 2-second drift synthesis via RTT trend slope */
uint64_t t_start = mpcp_now_raw_ns();
uint64_t t_end = t_start + 2000000000ULL;
double x_sum = 0.0, y_sum = 0.0, x2_sum = 0.0, xy_sum = 0.0;
size_t n = 0;
uint16_t seq = 1000;
while (mpcp_now_raw_ns() < t_end) {
double rtt_ms = 0.0;
uint64_t ts = 0, tr = 0;
if (cal_ping_once_raw(sock, cfg, peer_addr, sess->session_nonce, seq++, &rtt_ms, &ts, &tr) == MPCP_OK) {
double x = (double)(ts - t_start) / 1e9;
double y = rtt_ms / 2.0;
x_sum += x; y_sum += y; x2_sum += x * x; xy_sum += x * y;
n++;
}
struct timespec nap = { .tv_sec = 0, .tv_nsec = 2000000L };
nanosleep(&nap, NULL);
}
double slope_ms_per_s = 0.0;
if (n >= 2) {
double den = (double)n * x2_sum - x_sum * x_sum;
if (fabs(den) > 1e-12) slope_ms_per_s = (((double)n * xy_sum) - (x_sum * y_sum)) / den;
}
calib_out->drift_ppm = slope_ms_per_s * 1000.0;
calib_out->drift_coefficient = 1.0 + (calib_out->drift_ppm / 1000000.0);

/* Phase 3: dynamic cadence selection */
if (cfg->blink_interval_us > 0) {
calib_out->blink_interval_ns = (uint64_t)cfg->blink_interval_us * 1000ULL;
} else {
double jitter_us = sqrt(var) * 1000.0;
if (jitter_us < 100.0) calib_out->blink_interval_ns = 10000000ULL;
else if (jitter_us > 5000.0) calib_out->blink_interval_ns = 500000000ULL;
else if (jitter_us > 1000.0) calib_out->blink_interval_ns = 100000000ULL;
else calib_out->blink_interval_ns = 25000000ULL;
}

/* Phase 4: epoch handshake + bounded ghost verification */
calib_out->ghost_port = calib_ghost_port(cfg, sess);
struct sockaddr_in ghost_peer = *peer_addr;
ghost_peer.sin_port = htons(calib_out->ghost_port);
calib_out->tzero_ns = mpcp_now_raw_ns() + 2000000000ULL;
uint64_t fire_ns = calib_out->tzero_ns + calib_out->blink_interval_ns;
while (mpcp_now_raw_ns() < fire_ns) {
uint64_t rem = fire_ns - mpcp_now_raw_ns();
struct timespec ts = { .tv_sec = 0, .tv_nsec = (long)((rem > 1000000ULL) ? 1000000ULL : rem) };
nanosleep(&ts, NULL);
}
mpcp_cal_pkt_t ghost;
build_ping(&ghost, 0xEE01u, sess->session_nonce);
uint8_t wire[MPCP_CAL_WIRE_BUF];
size_t wire_len = sizeof(ghost);
if (cfg->disguise_calibration) {
wire_len = mpcp_disguise_wrap((const uint8_t *)&ghost, sizeof(ghost), wire,
sizeof(wire), cfg->disguise_protocol);
if (wire_len == 0) { close(sock); return MPCP_ERR_PROTO; }
} else {
memcpy(wire, &ghost, sizeof(ghost));
}
if (sendto(sock, wire, wire_len, 0, (const struct sockaddr *)&ghost_peer, sizeof(ghost_peer)) < 0) {
close(sock); return MPCP_ERR_IO;
}
struct timeval strict = { .tv_sec = 0, .tv_usec = (suseconds_t)((calib_out->blink_interval_ns / 4ULL) / 1000ULL) };
if (strict.tv_usec < 10000) strict.tv_usec = 10000;
if (strict.tv_usec > 250000) strict.tv_usec = 250000;
(void)setsockopt(sock, SOL_SOCKET, SO_RCVTIMEO, &strict, sizeof(strict));
uint8_t rx[MPCP_CAL_WIRE_BUF];
struct sockaddr_in from;
socklen_t fromlen = sizeof(from);
ssize_t rn = recvfrom(sock, rx, sizeof(rx), 0, (struct sockaddr *)&from, &fromlen);
if (rn > 0) {
size_t plen = (size_t)rn;
if (cfg->disguise_calibration)
plen = mpcp_disguise_unwrap(rx, plen, rx, sizeof(rx), cfg->disguise_protocol);
uint64_t ts_echo = 0;
if (plen > 0 && parse_pong(rx, plen, 0xEE01u, &ts_echo)) calib_out->handshake_locked = true;
}
close(sock);
if (!calib_out->handshake_locked) return MPCP_ERR_TIMEOUT;

result_out->trimmed_mean  = calib_out->stable_mean_rtt_ms;
result_out->median_rtt    = calib_out->stable_mean_rtt_ms;
result_out->mad           = sqrt(calib_out->jitter_variance_ms2);
result_out->robust_std    = result_out->mad;
result_out->ewma_rtt      = calib_out->stable_mean_rtt_ms;
result_out->baseline_mean = calib_out->stable_mean_rtt_ms;
result_out->baseline_std  = (result_out->robust_std > 1e-6) ? result_out->robust_std : 1e-6;
result_out->catch_window  = compute_catch_window(result_out->ewma_rtt,
result_out->robust_std,
cfg->stddev_multiplier,
(double)cfg->floor_buffer,
(double)cfg->max_catch_window);
result_out->sample_count  = calib_out->samples_kept;
return MPCP_OK;
}

void mpcp_cal_ewma_update(mpcp_rtt_result_t *result,
double new_rtt_ms,
double alpha)
{
result->ewma_rtt = ewma_update(result->ewma_rtt, new_rtt_ms, alpha);
}
double mpcp_cal_zscore(const mpcp_rtt_result_t *result, double oracle_rtt_ms)
{
if (result->baseline_std < 1e-9) return 0.0;
return (oracle_rtt_ms - result->baseline_mean) / result->baseline_std;
}
bool mpcp_cal_tripwire_fallback(const mpcp_rtt_result_t *result,
double oracle_rtt_ms)
{
return oracle_rtt_ms > result->baseline_mean * 3.0;
}
int mpcp_calibrate_collect_samples(const mpcp_config_t     *cfg,
const mpcp_session_t    *sess,
const struct sockaddr_in *peer,
double                  **samples_out,
uint32_t                *count_out,
mpcp_rtt_result_t       *result_out)
{
uint32_t ping_count = random_ping_count(cfg->ping_count_min,
cfg->ping_count_max);
double *rtts = calloc(ping_count, sizeof(double));
if (!rtts) return MPCP_ERR_ALLOC;
int sock = cal_socket_open();
if (sock < 0) { free(rtts); return MPCP_ERR_IO; }
size_t n;
if (cfg->slow_mode)
n = calibrate_slow(sock, peer, ping_count,
cfg->slow_mode_min_gap, cfg->slow_mode_max_gap,
sess->session_nonce, rtts,
cfg->disguise_calibration, cfg->disguise_protocol);
else
n = calibrate_standard(sock, peer, ping_count, cfg->batch_size,
sess->session_nonce, rtts,
cfg->disguise_calibration, cfg->disguise_protocol);
close(sock);
if (n < 10) { free(rtts); return MPCP_ERR_TIMEOUT; }
int rc = rtt_pipeline(rtts, n, cfg, result_out);
if (rc != MPCP_OK) { free(rtts); return rc; }
*samples_out = rtts;  
*count_out   = (uint32_t)n;
return MPCP_OK;
}
static void blink_calibrate_from_rtt(mpcp_session_t      *sess,
const mpcp_config_t *cfg,
const double        *rtt_ms,
uint32_t             n,
double               ewma_rtt_ms)
{
(void)rtt_ms; (void)n;
sess->clock_offset_ns = 0;
if (cfg->blink_interval_us > 0) {
sess->blink_interval_ns = (uint64_t)cfg->blink_interval_us * 1000ULL;
} else {
uint64_t rtt_half = (uint64_t)(ewma_rtt_ms * 500000.0);
sess->blink_interval_ns = rtt_half + 3000000ULL;
if (sess->blink_interval_ns < 5000000ULL)
sess->blink_interval_ns = 5000000ULL;
if (sess->blink_interval_ns > 200000000ULL)
sess->blink_interval_ns = 200000000ULL;
}
const uint64_t ORIGIN_GUARD_NS = 1500000000ULL;
sess->blink_origin_ns = mpcp_now_ns() + ORIGIN_GUARD_NS;
sess->t_zero_ns = sess->blink_origin_ns;
sess->drift_coefficient = 1.0;
fprintf(stderr, "[blink] calibrated: interval=%.1fms  origin_in=%.0fms\n",
(double)sess->blink_interval_ns / 1e6,
(double)(int64_t)(sess->blink_origin_ns - mpcp_now_ns()) / 1e6);
}
static void put_u16_be(uint8_t *p, uint16_t v)
{
p[0] = (uint8_t)(v >> 8);
p[1] = (uint8_t)(v);
}
static void put_u32_be(uint8_t *p, uint32_t v)
{
p[0] = (uint8_t)(v >> 24);
p[1] = (uint8_t)(v >> 16);
p[2] = (uint8_t)(v >>  8);
p[3] = (uint8_t)(v);
}
static uint16_t get_u16_be(const uint8_t *p)
{
return (uint16_t)(((uint16_t)p[0] << 8) | (uint16_t)p[1]);
}
#define DNS_HDR_LEN     12u
static const uint8_t DNS_QNAME[12] = {
0x04, 'm','p','c','p',
0x05, 'l','o','c','a','l',
0x00
};
#define DNS_QNAME_LEN   12u
#define DNS_FLAGS_RESP  0x8580u  
#define DNS_TYPE_TXT    0x0010u
#define DNS_CLASS_IN    0x0001u
#define DNS_TTL         0x00000078u  
#define DNS_OVERHEAD    (DNS_HDR_LEN + DNS_QNAME_LEN + 4u + DNS_QNAME_LEN + 10u + 1u)
static size_t dns_wrap(const uint8_t *src, size_t src_len,
uint8_t *dst, size_t dst_size)
{
if (src_len > 255u) return 0;
size_t total = DNS_OVERHEAD + src_len;
if (total > dst_size) return 0;
uint8_t *p = dst;
put_u16_be(p, 0x1234u); p += 2;  
put_u16_be(p, DNS_FLAGS_RESP); p += 2;
put_u16_be(p, 1u); p += 2;  
put_u16_be(p, 1u); p += 2;  
put_u16_be(p, 0u); p += 2;  
put_u16_be(p, 0u); p += 2;  
memcpy(p, DNS_QNAME, DNS_QNAME_LEN); p += DNS_QNAME_LEN;
put_u16_be(p, DNS_TYPE_TXT);  p += 2;
put_u16_be(p, DNS_CLASS_IN);  p += 2;
memcpy(p, DNS_QNAME, DNS_QNAME_LEN); p += DNS_QNAME_LEN;
put_u16_be(p, DNS_TYPE_TXT);  p += 2;
put_u16_be(p, DNS_CLASS_IN);  p += 2;
put_u32_be(p, DNS_TTL);       p += 4;
put_u16_be(p, (uint16_t)(1u + src_len)); p += 2;
*p++ = (uint8_t)(src_len & 0xFFu);
memcpy(p, src, src_len); p += src_len;
return (size_t)(p - dst);
}
static size_t dns_unwrap(const uint8_t *src, size_t src_len,
uint8_t *dst, size_t dst_size)
{
if (src_len < DNS_OVERHEAD) return 0;
const uint8_t *p = src;
p += DNS_HDR_LEN + DNS_QNAME_LEN + 4u + DNS_QNAME_LEN + 8u;
if ((size_t)(p - src) + 2u > src_len) return 0;
uint16_t rdlen = get_u16_be(p); p += 2;
if (rdlen < 1u) return 0;
if ((size_t)(p - src) + rdlen > src_len) return 0;
p++;  
size_t payload_len = (size_t)(rdlen - 1u);
if (payload_len > dst_size) return 0;
memcpy(dst, p, payload_len);
return payload_len;
}
#define NTP_HDR_LEN          48u
#define NTP_EXT_TYPE_MPCP    0x0421u
#define NTP_EXT_HDR_LEN      4u
static size_t ntp_wrap(const uint8_t *src, size_t src_len,
uint8_t *dst, size_t dst_size)
{
size_t pad     = (4u - (src_len & 3u)) & 3u;
size_t ext_len = NTP_EXT_HDR_LEN + src_len + pad;
size_t total   = NTP_HDR_LEN + ext_len;
if (total > dst_size) return 0;
uint8_t *p = dst;
memset(p, 0, NTP_HDR_LEN);
p[0] = (uint8_t)((4u << 3) | 3u);  
p[1] = 0;  
p[2] = 6;  
p[3] = (uint8_t)0xEC;  
put_u32_be(p + 40, 0xE6D89A00u);  
p += NTP_HDR_LEN;
put_u16_be(p, NTP_EXT_TYPE_MPCP); p += 2;
put_u16_be(p, (uint16_t)(ext_len & 0xFFFFu)); p += 2;
memcpy(p, src, src_len); p += src_len;
if (pad > 0) { memset(p, 0, pad); p += pad; }
return (size_t)(p - dst);
}
static size_t ntp_unwrap(const uint8_t *src, size_t src_len,
uint8_t *dst, size_t dst_size)
{
if (src_len < NTP_HDR_LEN + NTP_EXT_HDR_LEN) return 0;
const uint8_t *p         = src + NTP_HDR_LEN;
size_t         remaining  = src_len - NTP_HDR_LEN;
while (remaining >= NTP_EXT_HDR_LEN) {
uint16_t type = get_u16_be(p);
uint16_t elen = get_u16_be(p + 2);
if (elen < NTP_EXT_HDR_LEN || (size_t)elen > remaining) return 0;
if (type == NTP_EXT_TYPE_MPCP) {
size_t payload_len = (size_t)(elen - NTP_EXT_HDR_LEN);
if (payload_len > dst_size) return 0;
memcpy(dst, p + NTP_EXT_HDR_LEN, payload_len);
return payload_len;
}
p         += elen;
remaining -= elen;
}
return 0;
}
size_t mpcp_disguise_wrap(const uint8_t        *src,
size_t                src_len,
uint8_t              *dst,
size_t                dst_size,
mpcp_disguise_proto_t proto)
{
if (!src || !dst || src_len == 0 || dst_size == 0) return 0;
switch (proto) {
case MPCP_DISGUISE_DNS: return dns_wrap(src, src_len, dst, dst_size);
case MPCP_DISGUISE_NTP: return ntp_wrap(src, src_len, dst, dst_size);
default:
if (src_len > dst_size) return 0;
memcpy(dst, src, src_len);
return src_len;
}
}
size_t mpcp_disguise_unwrap(const uint8_t        *src,
size_t                src_len,
uint8_t              *dst,
size_t                dst_size,
mpcp_disguise_proto_t proto)
{
if (!src || !dst || src_len == 0 || dst_size == 0) return 0;
switch (proto) {
case MPCP_DISGUISE_DNS: return dns_unwrap(src, src_len, dst, dst_size);
case MPCP_DISGUISE_NTP: return ntp_unwrap(src, src_len, dst, dst_size);
default:
if (src_len > dst_size) return 0;
memcpy(dst, src, src_len);
return src_len;
}
}
#include <sys/stat.h>
#include <sys/random.h>
int mpcp_keygen_candidates(uint32_t n, mpcp_candidates_t *out)
{
if (!out || n == 0 || n > MPCP_MAX_CANDIDATES)
return MPCP_ERR_PARAM;
out->n    = 0;
out->keys = NULL;
out->keys = calloc(n, sizeof(uint8_t *));
if (!out->keys) return MPCP_ERR_ALLOC;
for (uint32_t i = 0; i < n; i++) {
out->keys[i] = sodium_malloc(32);
if (!out->keys[i]) {
mpcp_keygen_candidates_free(out);
return MPCP_ERR_ALLOC;
}
randombytes_buf(out->keys[i], 32);
out->n++;
}
return MPCP_OK;
}
void mpcp_keygen_candidates_free(mpcp_candidates_t *cands)
{
if (!cands) return;
if (cands->keys) {
for (uint32_t i = 0; i < cands->n; i++) {
if (cands->keys[i]) {
sodium_memzero(cands->keys[i], 32);
sodium_free(cands->keys[i]);
cands->keys[i] = NULL;
}
}
free(cands->keys);
cands->keys = NULL;
}
cands->n = 0;
}
void mpcp_keygen_candidates_wipe_losers(mpcp_candidates_t *cands,
uint32_t           keep_idx)
{
if (!cands || !cands->keys) return;
for (uint32_t i = 0; i < cands->n; i++) {
if (i == keep_idx) continue;
if (cands->keys[i]) {
sodium_memzero(cands->keys[i], 32);
sodium_free(cands->keys[i]);
cands->keys[i] = NULL;
}
}
}
static int key_path(const char *keydir, const char *filename,
char *buf, size_t buf_size)
{
int n = snprintf(buf, buf_size, "%s/%s", keydir, filename);
if (n < 0 || (size_t)n >= buf_size) return MPCP_ERR_PARAM;
return MPCP_OK;
}
static int mkdir_p(const char *path)
{
char tmp[512];
snprintf(tmp, sizeof(tmp), "%s", path);
size_t len = strlen(tmp);
if (len && tmp[len-1] == '/') tmp[len-1] = '\0';
for (char *p = tmp + 1; *p; p++) {
if (*p == '/') {
*p = '\0';
if (mkdir(tmp, 0700) != 0 && errno != EEXIST) return MPCP_ERR_IO;
*p = '/';
}
}
if (mkdir(tmp, 0700) != 0 && errno != EEXIST) return MPCP_ERR_IO;
return MPCP_OK;
}
static int write_key_file(const char *path, mode_t mode,
const uint8_t *data, size_t len)
{
int fd = open(path, O_WRONLY | O_CREAT | O_TRUNC, mode);
if (fd < 0) {
fprintf(stderr, "[keygen] open %s: %s\n", path, strerror(errno));
return MPCP_ERR_IO;
}
ssize_t written = write(fd, data, len);
close(fd);
if (written != (ssize_t)len) {
fprintf(stderr, "[keygen] write %s: short write\n", path);
return MPCP_ERR_IO;
}
return MPCP_OK;
}
static int read_key_file(const char *path, uint8_t *buf, size_t len)
{
int fd = open(path, O_RDONLY);
if (fd < 0) {
fprintf(stderr, "[keygen] open %s: %s\n", path, strerror(errno));
return MPCP_ERR_IO;
}
ssize_t n = read(fd, buf, len);
close(fd);
if (n != (ssize_t)len) {
fprintf(stderr, "[keygen] read %s: expected %zu got %zd\n", path, len, n);
return MPCP_ERR_IO;
}
return MPCP_OK;
}
int mpcp_ed25519_keygen(const char *keydir)
{
if (!keydir) return MPCP_ERR_PARAM;
int rc = mkdir_p(keydir);
if (rc != MPCP_OK) return rc;
char sk_path[512], pk_path[512];
if (key_path(keydir, "mpcp_ed25519.sk", sk_path, sizeof(sk_path)) != MPCP_OK)
return MPCP_ERR_PARAM;
if (key_path(keydir, "mpcp_ed25519.pk", pk_path, sizeof(pk_path)) != MPCP_OK)
return MPCP_ERR_PARAM;
if (access(sk_path, F_OK) == 0) {
fprintf(stderr, "[keygen] keypair already exists in %s\n", keydir);
return MPCP_OK;
}
uint8_t *pk = sodium_malloc(crypto_sign_PUBLICKEYBYTES);
uint8_t *sk = sodium_malloc(crypto_sign_SECRETKEYBYTES);
if (!pk || !sk) {
sodium_free(pk); sodium_free(sk);
return MPCP_ERR_ALLOC;
}
if (crypto_sign_keypair(pk, sk) != 0) {
sodium_memzero(sk, crypto_sign_SECRETKEYBYTES);
sodium_free(pk); sodium_free(sk);
return MPCP_ERR_CRYPTO;
}
rc = write_key_file(sk_path, 0600, sk, crypto_sign_SECRETKEYBYTES);
if (rc == MPCP_OK)
rc = write_key_file(pk_path, 0644, pk, crypto_sign_PUBLICKEYBYTES);
sodium_memzero(sk, crypto_sign_SECRETKEYBYTES);
sodium_free(pk);
sodium_free(sk);
if (rc == MPCP_OK)
fprintf(stderr, "[keygen] Ed25519 keypair written to %s\n", keydir);
return rc;
}
int mpcp_ed25519_load_sk(const char *keydir, uint8_t *sk_out)
{
char path[512];
if (key_path(keydir, "mpcp_ed25519.sk", path, sizeof(path)) != MPCP_OK)
return MPCP_ERR_PARAM;
return read_key_file(path, sk_out, crypto_sign_SECRETKEYBYTES);
}
