  static uint16_t blink_hop_port_subidx(const mpcp_session_t *sess,
  const mpcp_config_t *cfg,
  uint32_t chunk_idx,
  uint8_t sub_index)
  {
  uint32_t hop_interval = (cfg->port_hop_interval > 0) ? cfg->port_hop_interval : 1u;
  uint32_t hop_base     = (chunk_idx / hop_interval) * hop_interval;
  uint8_t nonce_x[MPCP_SESSION_NONCE_LEN];
  memcpy(nonce_x, sess->session_nonce, MPCP_SESSION_NONCE_LEN);
  nonce_x[chunk_idx % MPCP_SESSION_NONCE_LEN] ^= sub_index;
  uint8_t ikm[9 + 4 + MPCP_SESSION_NONCE_LEN];
  memcpy(ikm, "blink-hop", 9);
  ikm[9]  = (uint8_t)((hop_base >> 24) & 0xFF);
  ikm[10] = (uint8_t)((hop_base >> 16) & 0xFF);
  ikm[11] = (uint8_t)((hop_base >>  8) & 0xFF);
  ikm[12] = (uint8_t)( hop_base        & 0xFF);
  memcpy(ikm + 13, nonce_x, MPCP_SESSION_NONCE_LEN);
  uint8_t out[4];
  if (mpcp_hkdf(sess->session_key, MPCP_SESSION_KEY_LEN,
  ikm, sizeof(ikm), "mpcp-v0.5-blink-hop", out, 4) != MPCP_OK) {
  sodium_memzero(nonce_x, sizeof(nonce_x));
  return blink_hop_port(sess, cfg, chunk_idx);
  }
  sodium_memzero(nonce_x, sizeof(nonce_x));
  uint32_t seed = ((uint32_t)out[0] << 24) | ((uint32_t)out[1] << 16) |
  ((uint32_t)out[2] <<  8) |  (uint32_t)out[3];
  return (uint16_t)(seed % cfg->port_range + cfg->port_base);
  }
  static int32_t schedule_jitter_ns(const mpcp_session_t *sess, uint32_t seq)
  {
  uint8_t out[4];
  uint8_t ikm[8];
  ikm[0] = (uint8_t)(seq >> 24); ikm[1] = (uint8_t)(seq >> 16);
  ikm[2] = (uint8_t)(seq >>  8); ikm[3] = (uint8_t)seq;
  ikm[4] = 'j'; ikm[5] = 'i'; ikm[6] = 't'; ikm[7] = 'r';
  if (mpcp_hkdf(sess->session_key, MPCP_SESSION_KEY_LEN,
  ikm, sizeof(ikm), "mpcp-v0.5-heisenberg-jitter", out, 4) != MPCP_OK)
  return 0;
  uint32_t v = ((uint32_t)out[0] << 24) | ((uint32_t)out[1] << 16) |
  ((uint32_t)out[2] << 8) | (uint32_t)out[3];
  int32_t span = 100001; /* [-50000, +50000] ns */
  return (int32_t)(v % (uint32_t)span) - 50000;
  }
  static void mpcp_generate_schedule(const mpcp_session_t *sess,
  const mpcp_config_t *cfg,
  const uint32_t *seqs,
  uint32_t n,
  uint64_t tzero_ns,
  uint64_t interval_ns,
  double drift_coefficient,
  schedule_entry_t *out)
  {
  for (uint32_t i = 0; i < n; i++) {
  uint32_t seq = seqs[i];
