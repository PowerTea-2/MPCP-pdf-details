  uint16_t _port;
  /* O(1) on-the-fly key derivation — no keystream heap */
  mpcp_get_chunk_params(ctx->sess, ctx->cfg, seq, chunk_key, &_port);
  size_t  plain_len = 0;
  uint8_t *plain = ctx->decrypt_buf;
  if (!plain) {
  sodium_memzero(chunk_key, sizeof(chunk_key));
  mpcp_ring_release(&ctx->ring1, in);
  continue;
  }
