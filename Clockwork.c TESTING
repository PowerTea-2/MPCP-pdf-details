  real_len = (uint32_t)plain_len;
  if (!ctx->chunk_store[_local_dec]) {
  ctx->chunk_store[_local_dec] = malloc(real_len);
  if (ctx->chunk_store[_local_dec]) {
  memcpy(ctx->chunk_store[_local_dec], plain, real_len);
  ctx->chunk_lens[_local_dec]  = real_len;
  ctx->chunk_ready[_local_dec] = true;
  }
